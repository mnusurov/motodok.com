---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const products = (await getCollection('products')).filter(p => p.data.pdfFiles && p.data.pdfFiles.length > 0);
---

<BaseLayout title="Документация — Motodok" description="Техническая документация, инструкции, руководства по оборудованию для автодиагностики">
  <h1>Документация</h1>

  {products.length > 0 ? (
    <div class="docs-list">
      {products.map(item => {
        const cat = item.data.category === 'diagnosis' ? 'Diagnosis' : item.data.category === 'measure' ? 'Measure' : item.data.category === 'immobilizer' ? 'Immobilizer' : item.data.category === 'odometers' ? 'Odometers' : 'Databases';
        return (
          <section class="doc-group">
            <h2><a href={`/${cat}/${item.slug}/`}>{item.data.title}</a></h2>
            <ul class="doc-files">
              {item.data.pdfFiles.map(f => (
                <li><a href={f} target="_blank" rel="noopener noreferrer">{f.split('/').pop() || 'Скачать PDF'}</a></li>
              ))}
            </ul>
          </section>
        );
      })}
    </div>
  ) : (
    <p>Документация скоро появится</p>
  )}
</BaseLayout>

<style>
  .doc-group { margin-bottom: 2rem; }
  .doc-group h2 { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; }
  .doc-group h2 a { color: var(--accent); }
  .doc-files { list-style: none; padding: 0; }
  .doc-files li { margin-bottom: 4px; }
  .doc-files a { color: var(--text2); font-size: .9rem; }
  .doc-files a:hover { color: var(--accent); }
</style>
