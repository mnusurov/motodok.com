---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const products = (await getCollection('products')).filter(p => p.data.pdfFiles && p.data.pdfFiles.length > 0);
---
<BaseLayout
  title="Документация — Motodok"
  description="Техническая документация, инструкции, руководства по оборудованию для автодиагностики"
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Документация' },
  ]}
>
  <h1>Документация</h1>

  {products.length > 0 ? (
    <div class="docs-list">
      {products.map(item => (
        <section class="doc-group">
          <h2><a href={`/${item.data.category === 'diagnosis' ? 'Diagnosis' : item.data.category === 'measure' ? 'Measure' : item.data.category === 'immobilizer' ? 'Immobilizer' : item.data.category === 'odometers' ? 'Odometers' : 'Databases'}/${item.slug}/`}>{item.data.title}</a></h2>
          <ul class="doc-files">
            {item.data.pdfFiles.map(f => (
              <li><a href={f} target="_blank" rel="noopener noreferrer">{f.split('/').pop() || 'Скачать PDF'}</a></li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  ) : (
    <p>Документация скоро появится</p>
  )}
</BaseLayout>
