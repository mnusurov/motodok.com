---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { sortProducts } from '../../lib/productSort';
import { svg, catIcon } from '../../lib/icons';

const category = (await getCollection('categories')).find(c => c.data.slug === 'battery-service');
const products = sortProducts(
  (await getCollection('products'))
  .filter(p => p.data.category === 'battery-service')
);

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: category?.data.title || 'Сервис батарей EV/гибрид',
  description: category?.data.description || 'Оборудование для сервиса высоковольтных батарей',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: { '@type': 'Product', name: p.data.title, url: `${siteUrl}/battery-service/${p.slug}/` },
    })),
  },
};
---

<BaseLayout
  title={category?.data.metaTitle || category?.data.title || 'Сервис батарей EV/гибрид'}
  description={category?.data.metaDescription || category?.data.description || 'Оборудование для сервиса высоковольтных батарей'}
  ogImage={category?.data.image}
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Сервис батарей EV/гибрид' } ]}
>
  <PageHeader title={category?.data.title || 'Сервис батарей EV/гибрид'} lead={category?.data.description} icon={svg(catIcon['battery-service'], 28)} />

  <ProductGrid
    products={products.map(p => ({
      ...p.data,
      category: 'battery-service',
      slug: p.slug,
    }))}
  />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
