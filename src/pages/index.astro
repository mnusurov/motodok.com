---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/ProductGrid.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { getCollection } from 'astro:content';

const featuredProducts = (await getCollection('products')).filter(p => p.data.featured);
const categories = await getCollection('categories');

const categorySlugMap: Record<string, string> = {
  diagnosis: 'Diagnosis',
  measure: 'Measure',
  immobilizer: 'Immobilizer',
  odometers: 'Odometers',
  databases: 'Databases',
};
---
<BaseLayout title="Motodok" description="Оборудование для автодиагностики. Профессиональные сканеры, осциллографы, иммобилайзеры.">
  <section class="hero">
    <h1>Оборудование для автодиагностики</h1>
    <p>Профессиональные сканеры, осциллографы, иммобилайзеры и оборудование для ремонта электронных блоков управления</p>
  </section>

  {categories.length > 0 && (
    <section class="categories-section">
      <h2>Категории</h2>
      <div class="category-grid">
        {categories
          .sort((a, b) => a.data.order - b.data.order)
          .map(c => (
            <CategoryCard category={{ ...c.data, slug: categorySlugMap[c.data.slug] || c.data.slug }} />
          ))}
      </div>
    </section>
  )}

  {featuredProducts.length > 0 && (
    <section class="featured-section">
      <h2>Рекомендуемые товары</h2>
      <ProductGrid
        products={featuredProducts.map(p => ({
          ...p.data,
          category: categorySlugMap[p.data.category] || p.data.category,
          slug: p.slug,
        }))}
      />
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 1rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: #fff;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }
  .hero p {
    font-size: 1.1rem;
    opacity: 0.85;
    max-width: 600px;
    margin: 0 auto;
  }
  .categories-section, .featured-section {
    margin-bottom: 2rem;
  }
  .categories-section h2, .featured-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
