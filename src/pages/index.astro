---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { testimonials } from '../data/testimonials';
import { advantages } from '../data/advantages';
import { socialPlatforms } from '../data/social';
import { getCollection } from 'astro:content';
import { brandSvg } from '../lib/brandLogo';

const products = await getCollection('products');
const categories = await getCollection('categories');
const brands = await getCollection('brands');
const articles = (await getCollection('articles')).sort((a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0));
const newsItems = (await getCollection('news')).sort((a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0));

const categorySlugMap: Record<string, string> = {
  diagnosis: 'Diagnosis',
  measure: 'Measure',
  immobilizer: 'Immobilizer',
  odometers: 'Odometers',
  databases: 'Databases',
};

// Line icons (Lucide-style), rendered inline as currentColor strokes
const icons: Record<string, string> = {
  wrench: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  activity: '<path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/>',
  key: '<circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/>',
  gauge: '<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  tool: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  award: '<path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/>',
  package: '<path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="M3.3 7 12 12l8.7-5"/><path d="M12 22V12"/>',
  tag: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  truck: '<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/>',
  badge: '<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>',
  wallet: '<path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/>',
  arrow: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
  star: '<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.12 2.12 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.12 2.12 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.12 2.12 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.12 2.12 0 0 0 1.597-1.16z" fill="currentColor" stroke="none"/>',
};

const svg = (key: string, size = 24) =>
  `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">${icons[key] || ''}</svg>`;

const catIcon: Record<string, string> = {
  diagnosis: 'wrench',
  measure: 'activity',
  immobilizer: 'key',
  odometers: 'gauge',
  databases: 'database',
  services: 'tool',
};

const sampleProducts = products.slice(0, 8);
const mixedNews = [
  ...articles.slice(0, 3).map(a => ({ title: a.data.title, date: a.data.publishedDate, href: `/Articles/${a.slug}/`, type: 'article' as const })),
  ...newsItems.slice(0, 3).map(n => ({ title: n.data.title, date: n.data.publishedDate, href: `/News/${n.slug}/`, type: 'news' as const })),
].sort((a, b) => (b.date?.getTime() || 0) - (a.date?.getTime() || 0)).slice(0, 4);
const dayNames = ['воскресенье', 'понедельник', 'вторник', 'среда', 'четверг', 'пятница', 'суббота'];

function formatDateRu(d: Date): string {
  const day = dayNames[d.getDay()];
  const date = d.getDate();
  const months = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];
  return `${day}, ${date} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

const stats = [
  { number: '19+', label: 'лет на рынке', icon: 'award' },
  { number: `${products.length}+`, label: 'товаров в каталоге', icon: 'package' },
  { number: `${brands.length}`, label: 'брендов', icon: 'tag' },
  { number: '1000+', label: 'довольных клиентов', icon: 'users' },
];

function getInitials(name: string): string {
  return name.split(' ').map(s => s[0]).join('');
}
---

<BaseLayout title="Продажа оборудования для автодиагностики" description="Дилерские сканеры, адаптеры, осциллографы и базы данных для автосервисов и профессионалов" wide={true}>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container">
      <span class="hero-badge">Профессиональная автодиагностика с 2007 года</span>
      <h1>Оборудование для <span>автодиагностики</span></h1>
      <p>Дилерские сканеры, адаптеры, осциллографы и базы данных для автосервисов и профессионалов</p>
      <div class="hero-cta">
        <a href="/Diagnosis/" class="btn-primary">Смотреть каталог <Fragment set:html={svg('arrow', 18)} /></a>
        <a href="/contacts/" class="btn-secondary">Связаться</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="stats-grid">
        {stats.map(s => (
          <div class="stat-card">
            <span class="icon-badge"><Fragment set:html={svg(s.icon)} /></span>
            <div class="stat-number">{s.number}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Каталог</span>
        <h2>Категории оборудования</h2>
        <p class="section-sub">От дилерских сканеров до баз данных — всё для профессиональной диагностики автомобилей.</p>
      </div>
      <div class="category-grid">
        {categories.sort((a, b) => a.data.order - b.data.order).map(c => {
          const slug = categorySlugMap[c.data.slug] || c.data.slug;
          return (
            <a href={`/${slug}/`} class="category-card">
              <span class="icon-badge"><Fragment set:html={svg(catIcon[c.data.slug] || 'wrench', 28)} /></span>
              <span class="cat-name">{c.data.title}</span>
              <span class="cat-arrow">Смотреть <Fragment set:html={svg('arrow', 15)} /></span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {brands.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Поддержка марок</span>
          <h2>Работаем со всеми брендами</h2>
        </div>
        <div class="brands-carousel-wrap">
          <div class="brands-carousel">
            {[...brands, ...brands].map(b => {
              const logo = brandSvg(b.data.slug);
              return (
                <span class="brand-logo" title={b.data.title}>
                  {logo
                    ? <Fragment set:html={logo} />
                    : <span class="brand-wordmark">{b.data.title}</span>}
                </span>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Преимущества</span>
        <h2>Почему выбирают Motodok</h2>
        <p class="section-sub">Прямые поставки, гарантия на каждое устройство и экспертная поддержка при выборе.</p>
      </div>
      <div class="advantages-grid">
        {advantages.map(a => (
          <div class="advantage-card">
            <span class="icon-badge"><Fragment set:html={svg(a.icon)} /></span>
            <h3>{a.title}</h3>
            <p>{a.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {sampleProducts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Витрина</span>
          <h2>Популярное оборудование</h2>
          <p class="section-sub">Проверенные сканеры и комплексы, которые чаще всего выбирают автосервисы.</p>
        </div>
        <div class="product-grid">
          {sampleProducts.map(p => {
            const cat = categorySlugMap[p.data.category] || p.data.category;
            return (
              <ProductCard product={{
                title: p.data.title,
                slug: p.slug,
                category: cat,
                price: p.data.price?.toString(),
                images: p.data.images,
                features: p.data.features,
                metaDescription: p.data.description?.slice(0, 200),
              }} />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Отзывы</span>
        <h2>Нам доверяют профессионалы</h2>
        <p class="section-sub">Автосервисы и диагносты по всему СНГ уже работают с нашим оборудованием.</p>
      </div>
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class="testimonial-card">
            <div class="testimonial-stars">
              {Array.from({ length: 5 }).map(() => <Fragment set:html={svg('star', 16)} />)}
            </div>
            <div class="testimonial-text">{t.text}</div>
            <div class="testimonial-author">
              <div class="testimonial-avatar">{getInitials(t.name)}</div>
              <div>
                <div class="testimonial-name">{t.name}</div>
                <div class="testimonial-role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {mixedNews.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Блог</span>
          <h2>Новости и статьи</h2>
          <p class="section-sub">Обзоры оборудования, гайды по диагностике и новости индустрии.</p>
        </div>
        <div class="news-grid">
          {mixedNews.map(item => (
            <a href={item.href} class="news-card">
              <span class="news-tag">{item.type === 'article' ? 'Статья' : 'Новость'}</span>
              {item.date && <time>{formatDateRu(item.date)}</time>}
              <h3>{item.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Соцсети</span>
        <h2>Мы на связи</h2>
      </div>
      <div class="social-links">
        {socialPlatforms.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer" class="social-link">
            <span class="social-icon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                {p.icon === 'telegram' && <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>}
                {p.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>}
                {p.icon === 'facebook' && <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>}
                {p.icon === 'twitter' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                {p.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
              </svg>
            </span>
            <span class="social-name">{p.name}</span>
            <span class="social-username">{p.username}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Свяжитесь с нами</h2>
      <p>Получите консультацию по подбору оборудования</p>
      <div class="cta-phone">+996 (772) 553-731</div>
      <div class="hero-cta">
        <a href="/contacts/" class="btn-primary">Написать нам</a>
        <a href="/Diagnosis/" class="btn-secondary">Перейти в каталог</a>
      </div>
    </div>
  </section>
</BaseLayout>
