---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const categories = await getCollection('categories');
const articles = (await getCollection('articles')).sort((a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0));
const newsItems = (await getCollection('news')).sort((a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0));

const categorySlugMap: Record<string, string> = {
  diagnosis: 'Diagnosis',
  measure: 'Measure',
  immobilizer: 'Immobilizer',
  odometers: 'Odometers',
  databases: 'Databases',
};

const catEmoji: Record<string, string> = {
  diagnosis: '\u{1F527}',
  measure: '\u{1F4C8}',
  immobilizer: '\u{1F510}',
  odometers: '\u{1F522}',
  databases: '\u{1F4BF}',
  services: '\u{1F529}',
};

const sampleProducts = products.slice(0, 8);
const mixedNews = [
  ...articles.slice(0, 2).map(a => ({ title: a.data.title, date: a.data.publishedDate, href: `/Articles/${a.slug}/`, type: 'article' as const })),
  ...newsItems.slice(0, 2).map(n => ({ title: n.data.title, date: n.data.publishedDate, href: `/News/${n.slug}/`, type: 'news' as const })),
].sort((a, b) => (b.date?.getTime() || 0) - (a.date?.getTime() || 0)).slice(0, 4);
const dayNames = ['воскресенье', 'понедельник', 'вторник', 'среда', 'четверг', 'пятница', 'суббота'];

function formatDateRu(d: Date): string {
  const day = dayNames[d.getDay()];
  const date = d.getDate();
  const months = ['января', 'февраля', 'марта', 'апреля', 'мая', 'июня', 'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'];
  return `${day}, ${date} ${months[d.getMonth()]} ${d.getFullYear()}`;
}
---

<BaseLayout title="Motodok — Продажа оборудования для автодиагностики" description="Дилерские сканеры, адаптеры, осциллографы и базы данных для автосервисов и профессионалов">
  <section class="hero">
    <div class="container">
      <h1>Оборудование для <span>автодиагностики</span></h1>
      <p>Дилерские сканеры, адаптеры, осциллографы и базы данных для автосервисов и профессионалов</p>
      <div class="hero-cta">
        <a href="/Diagnosis/" class="btn-primary">Смотреть каталог</a>
        <a href="/contacts/" class="btn-secondary">Связаться</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Категории</h2>
      <div class="category-grid">
        {categories.sort((a, b) => a.data.order - b.data.order).map(c => {
          const slug = categorySlugMap[c.data.slug] || c.data.slug;
          return (
            <a href={`/${slug}/`} class="category-card">
              <span class="cat-icon">{catEmoji[c.data.slug] || '🔧'}</span>
              <span class="cat-name">{c.data.title}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {sampleProducts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>Популярное оборудование</h2>
        <div class="product-grid">
          {sampleProducts.map(p => {
            const cat = categorySlugMap[p.data.category] || p.data.category;
            return (
              <a href={`/${cat}/${p.slug}/`} class="product-card">
                <h3>{p.data.title}</h3>
                <p>{p.data.description?.slice(0, 200)}</p>
                {p.data.price && <div class="price">{p.data.price}$</div>}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {mixedNews.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>Новости и статьи</h2>
        <div class="news-grid">
          {mixedNews.map(item => (
            <a href={item.href} class="news-card">
              {item.date && <time>{formatDateRu(item.date)}</time>}
              <h3>{item.title}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
