---
import VariantA from '../components/prototype/VariantA.astro';
import VariantB from '../components/prototype/VariantB.astro';
import VariantC from '../components/prototype/VariantC.astro';
import PrototypeSwitcher from '../components/prototype/PrototypeSwitcher.astro';
import { getCollection } from 'astro:content';

const featuredProducts = (await getCollection('products')).filter(p => p.data.featured);
const products = await getCollection('products');
const categories = await getCollection('categories');
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Motodok — Оборудование для автодиагностики</title>
  <meta name="description" content="Оборудование для автодиагностики. Профессиональные сканеры, осциллографы, иммобилайзеры." />
  <link rel="icon" href="/favicon.ico" />
</head>
<body style="margin:0;background:#fff">
  <div id="variant-a"><VariantA categories={categories} products={products.map(p => ({ ...p.data, slug: p.slug }))} /></div>
  <div id="variant-b" hidden><VariantB categories={categories} products={products.map(p => ({ ...p.data, slug: p.slug }))} /></div>
  <div id="variant-c" hidden><VariantC categories={categories} products={products.map(p => ({ ...p.data, slug: p.slug }))} /></div>

  <PrototypeSwitcher />

  <noscript>
    <style>#variant-a, #variant-b, #variant-c { display: block !important; } #variant-b, #variant-c { display: none !important; }</style>
  </noscript>
</body>
</html>
