---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductGrid from '../../../components/ProductGrid.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map(b => ({
    params: { slug: b.data.slug },
    props: { entry: b },
  }));
}

const { entry } = Astro.props;
const brand = entry.data;
const products = (await getCollection('products'))
  .filter(p => p.data.category === 'diagnosis' && p.data.brand === brand.slug)
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'Brand',
  name: brand.title,
  ...(brand.description && { description: brand.description }),
  ...(brand.country && { country: brand.country }),
};
---
<BaseLayout
  title={`${brand.title} — оборудование для диагностики`}
  description={brand.description || `Оборудование ${brand.title} для автодиагностики`}
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Диагностика', href: '/Diagnosis/' },
    { label: brand.title },
  ]}
>
  <h1>{brand.title}</h1>
  {brand.description && <p style="color:var(--text2);margin-bottom:1rem">{brand.description}</p>}
  {brand.country && <p style="color:var(--text2);font-size:.85rem;margin-bottom:1.5rem">Страна: {brand.country}</p>}

  {products.length > 0 ? (
    <ProductGrid
      products={products.map(p => ({
        ...p.data,
        category: 'Diagnosis',
        slug: p.slug,
      }))}
    />
  ) : (
    <p>Товары данного производителя не найдены</p>
  )}
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
