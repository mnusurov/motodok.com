---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getImage } from 'astro:assets';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles')).sort(
  (a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0)
);

const articleThumbs = await Promise.all(allArticles.map(async item => {
  if (!item.data.image) return null;
  const img = await getImage({ src: item.data.image, width: 400, height: 160, fit: 'cover', format: 'webp' });
  return { slug: item.slug, src: img.src };
}));
const thumbMap = new Map(articleThumbs.filter(Boolean).map(t => [t.slug, t.src]));
---

<BaseLayout title="Статьи" description="Полезные статьи по автодиагностике, ремонту электроники, выбору оборудования"
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Статьи' } ]}>
  <PageHeader eyebrow="Материалы" title="Статьи" lead="Гайды по диагностике, обзоры оборудования и советы по выбору." />

  {allArticles.length > 0 ? (
    <div class="listing-grid">
      {allArticles.map(item => (
        <a href={`/articles/${item.slug}/`} class="listing-card">
          {thumbMap.has(item.slug) && <img src={thumbMap.get(item.slug)} alt={item.data.title} loading="lazy" width="400" height="160" />}
          {item.data.publishedDate && <time>{item.data.publishedDate.toLocaleDateString('ru-RU')}</time>}
          <h3>{item.data.title}</h3>
          {item.data.description && <p>{item.data.description}</p>}
          <span class="listing-more">Читать<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>
      ))}
    </div>
  ) : (
    <p>Статьи скоро появятся</p>
  )}
</BaseLayout>
