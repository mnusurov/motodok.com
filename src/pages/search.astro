---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Поиск';
const description = 'Поиск по каталогу motodok.com';
---

<BaseLayout title={title} description={description}>
  <div class="search-page">
    <h1>Поиск по сайту</h1>
    <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css">
    <pagefind-searchbox></pagefind-searchbox>
    <script src="/pagefind/pagefind-component-ui.js" type="module"></script>
  </div>
</BaseLayout>

<style>
  .search-page {
    min-height: 60vh;
  }
  .search-page h1 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text);
  }
  pagefind-searchbox {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-text-hover: var(--accent);
    --pagefind-ui-background: var(--bg2);
    --pagefind-ui-background-hover: var(--bg2);
    --pagefind-ui-background-active: var(--bg2);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-border-radius: var(--radius);
  }
</style>
