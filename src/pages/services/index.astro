---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const allServices = await getCollection('services');

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Услуги по диагностике',
  description: 'Услуги по ремонту и обслуживанию диагностического оборудования',
  url: `${siteUrl}/services/`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: allServices.map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: { '@type': 'Service', name: s.data.title, url: `${siteUrl}/services/${s.slug}/` },
    })),
  },
};
---

<BaseLayout title="Услуги по диагностике" description="Услуги по ремонту и обслуживанию диагностического оборудования"
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Услуги' } ]}>
  <PageHeader eyebrow="Сервис" title="Услуги" lead="Ремонт и обслуживание диагностического оборудования." />

  {allServices.length > 0 ? (
    <div class="listing-grid">
      {allServices.map(item => (
        <a href={`/services/${item.slug}/`} class="listing-card">
          <h3>{item.data.title}</h3>
          <div class="price">{item.data.price ? `${item.data.price} $` : 'Договорная'}</div>
        </a>
      ))}
    </div>
  ) : (
    <p>Услуги скоро появятся</p>
  )}
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
