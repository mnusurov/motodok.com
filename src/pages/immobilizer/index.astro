---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { svg, catIcon } from '../../lib/icons';

const category = (await getCollection('categories')).find(c => c.data.slug === 'immobilizer');
const products = (await getCollection('products'))
  .filter(p => p.data.category === 'immobilizer')
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: category?.data.title || 'Иммобилайзеры',
  description: category?.data.description || 'Оборудование для работы с иммобилайзерами',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: { '@type': 'Product', name: p.data.title, url: `${siteUrl}/immobilizer/${p.slug}/` },
    })),
  },
};
---

<BaseLayout
  title={category?.data.metaTitle || category?.data.title || 'Иммобилайзеры'}
  description={category?.data.metaDescription || category?.data.description || 'Оборудование для работы с иммобилайзерами'}
  ogImage={category?.data.image}
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Иммобилайзеры' } ]}
>
  <PageHeader eyebrow="Каталог" title={category?.data.title || 'Иммобилайзеры'} lead={category?.data.description} icon={svg(catIcon.immobilizer, 28)} />

  <ProductGrid
    products={products.map(p => ({
      ...p.data,
      category: 'immobilizer',
      slug: p.slug,
    }))}
  />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
