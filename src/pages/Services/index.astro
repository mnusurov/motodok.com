---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allServices = await getCollection('services');
---

<BaseLayout title="Услуги — Motodok" description="Услуги по ремонту и обслуживанию диагностического оборудования"
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Услуги' } ]}>
  <h1>Услуги</h1>

  {allServices.length > 0 ? (
    <div class="listing-grid">
      {allServices.map(item => (
        <a href={`/Services/${item.slug}/`} class="listing-card">
          <h3>{item.data.title}</h3>
          {item.data.price && <div class="price" style="color:var(--accent);font-weight:700">{item.data.price}</div>}
        </a>
      ))}
    </div>
  ) : (
    <p>Услуги скоро появятся</p>
  )}
</BaseLayout>
