---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allServices = await getCollection('services');
---
<BaseLayout
  title="Услуги — Motodok"
  description="Услуги по ремонту и обслуживанию диагностического оборудования"
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Услуги' },
  ]}
>
  <h1>Услуги</h1>

  {allServices.length > 0 ? (
    <div class="services-grid">
      {allServices.map(item => (
        <article class="service-card">
          <a href={`/Services/${item.slug}/`} class="service-card-link">
            {item.data.image && <img src={item.data.image} alt={item.data.title} loading="lazy" class="service-card-img" />}
            <div class="service-card-body">
              <h2 class="service-card-title">{item.data.title}</h2>
              <p class="service-card-desc">{item.data.description}</p>
              {item.data.price && <span class="service-card-price">{item.data.price}</span>}
            </div>
          </a>
        </article>
      ))}
    </div>
  ) : (
    <p>Услуги скоро появятся</p>
  )}
</BaseLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .service-card {
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .service-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .service-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .service-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .service-card-body {
    padding: 0.75rem;
  }
  .service-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }
  .service-card-desc {
    font-size: 0.85rem;
    color: #666;
    margin: 0 0 0.5rem;
  }
  .service-card-price {
    font-weight: 700;
    color: #c0392b;
  }
</style>
