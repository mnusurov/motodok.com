---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allServices = await getCollection('services');
  return allServices.map(item => ({
    params: { slug: item.slug },
    props: { entry: item },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();
---

<BaseLayout
  title={data.metaTitle || `${data.title} — Motodok`}
  description={data.metaDescription || data.description}
  ogImage={data.image}
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Услуги', href: '/Services/' }, { label: data.title } ]}
>
  <article>
    <h1>{data.title}</h1>
    <div style="font-size:1.5rem;font-weight:700;color:var(--accent);margin-bottom:1rem">{data.price ? `${data.price} $` : 'Цена: договорная'}</div>
    {data.image && <img src={data.image} alt={data.title} loading="lazy" style="border-radius:var(--radius);margin-bottom:1.5rem;max-width:100%" />}
    <Content />
  </article>
</BaseLayout>
