---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsArticleJsonLd from '../../components/NewsArticleJsonLd.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map(item => ({
    params: { slug: item.slug },
    props: { entry: item },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();
---

<BaseLayout
  title={data.metaTitle || data.title}
  description={data.metaDescription || data.description}
  ogImage={data.image}
  ogType="article"
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Блог', href: '/blog/' }, { label: data.title } ]}
>
  <article>
    {data.publishedDate && <time style="display:block;color:var(--accent);font-size:.85rem;margin-bottom:.5rem;font-weight:600">{data.publishedDate.toLocaleDateString('ru-RU')}</time>}
    <h1>{data.title}</h1>
    {data.image && <img src={data.image} alt={data.title} loading="lazy" style="border-radius:var(--radius);margin-bottom:1.5rem;max-width:100%" />}
    <Content />
    <NewsArticleJsonLd
      title={data.title}
      description={data.description}
      image={data.image}
      publishedDate={data.publishedDate}
      updatedDate={data.updatedDate}
    />
  </article>
</BaseLayout>
