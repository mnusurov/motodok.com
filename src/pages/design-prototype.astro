---
// PROTOTYPE — throwaway. Три варианта редизайна главной, переключение через ?variant= (a|b|c)
// и плавающую панель внизу. Не линковать, не индексировать, не деплоить как есть.
import { getCollection } from 'astro:content';
import { testimonials } from '../data/testimonials';
import { advantages } from '../data/advantages';
import { brandSvg } from '../lib/brandLogo';
import VariantA from '../components/prototype/PrototypeVariantA.astro';
import VariantB from '../components/prototype/PrototypeVariantB.astro';
import VariantC from '../components/prototype/PrototypeVariantC.astro';

const productsRaw = await getCollection('products');
const categoriesRaw = await getCollection('categories');
const brandsRaw = await getCollection('brands');
const articlesRaw = (await getCollection('articles')).sort((a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0));
const newsRaw = (await getCollection('news')).sort((a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0));

const categorySlugMap: Record<string, string> = {
  diagnosis: 'diagnosis', measure: 'measure', immobilizer: 'immobilizer', odometers: 'odometers', databases: 'databases',
};

const showcase = productsRaw
  .filter(p => p.data.images?.length && typeof p.data.price === 'number' && p.data.inStock)
  .sort((a, b) => (b.data.price || 0) - (a.data.price || 0))
  .slice(0, 8)
  .map(p => ({
    title: p.data.title,
    href: `/${categorySlugMap[p.data.category] || p.data.category}/${p.slug}/`,
    price: p.data.price as number,
    image: p.data.images[0],
    category: p.data.category,
  }));

const categories = categoriesRaw
  .sort((a, b) => a.data.order - b.data.order)
  .map(c => ({
    title: c.data.title,
    href: `/${categorySlugMap[c.data.slug] || c.data.slug}/`,
    slug: c.data.slug,
    count: productsRaw.filter(p => p.data.category === c.data.slug).length,
  }));

const brands = brandsRaw.map(b => ({ title: b.data.title, logo: brandSvg(b.data.slug) }));

const news = [
  ...articlesRaw.slice(0, 3).map(a => ({ title: a.data.title, date: a.data.publishedDate, href: `/articles/${a.slug}/`, type: 'Статья' })),
  ...newsRaw.slice(0, 3).map(n => ({ title: n.data.title, date: n.data.publishedDate, href: `/blog/${n.slug}/`, type: 'Блог' })),
].sort((a, b) => (b.date?.getTime() || 0) - (a.date?.getTime() || 0)).slice(0, 4)
  .map(i => ({ ...i, dateStr: i.date ? i.date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }) : '' }));

const stats = [
  { number: 19, suffix: '+', label: 'лет на рынке' },
  { number: productsRaw.length, suffix: '+', label: 'позиций в каталоге' },
  { number: brandsRaw.length, suffix: '', label: 'брендов' },
  { number: 1000, suffix: '+', label: 'клиентов по СНГ' },
];

const data = { showcase, categories, brands, news, stats, advantages, testimonials };

const variants = [
  { key: 'a', name: 'Инженерный монохром' },
  { key: 'b', name: 'Diagnostic HUD' },
  { key: 'c', name: 'Премиум-шоурум' },
];
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>PROTOTYPE — редизайн главной Motodok</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="proto-variant" data-key="a"><VariantA {...data} /></div>
  <div class="proto-variant" data-key="b" hidden><VariantB {...data} /></div>
  <div class="proto-variant" data-key="c" hidden><VariantC {...data} /></div>

  <nav class="proto-switcher" aria-label="Переключатель вариантов">
    <button type="button" data-dir="-1" aria-label="Предыдущий вариант">&larr;</button>
    <span class="proto-label" id="protoLabel"></span>
    <button type="button" data-dir="1" aria-label="Следующий вариант">&rarr;</button>
  </nav>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
    html { scroll-behavior: smooth }
    img { max-width: 100%; height: auto; display: block }
    a { text-decoration: none; color: inherit }
    button { font: inherit; cursor: pointer }
    .proto-switcher {
      position: fixed; bottom: 18px; left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: 4px;
      background: #111; color: #fff; border: 1px solid rgba(255,255,255,.25);
      border-radius: 999px; padding: 6px 8px; z-index: 9999;
      box-shadow: 0 8px 30px rgba(0,0,0,.45);
      font-family: 'JetBrains Mono', monospace; font-size: 13px;
    }
    .proto-switcher button {
      background: none; border: none; color: #fff; width: 34px; height: 34px;
      border-radius: 50%; font-size: 16px; transition: background .15s;
    }
    .proto-switcher button:hover { background: rgba(255,255,255,.15) }
    .proto-label { padding: 0 10px; white-space: nowrap; user-select: none }
    /* общие хелперы анимаций для всех вариантов */
    .reveal { opacity: 0; transform: translateY(44px) scale(.985); transition: opacity .85s ease, transform .85s cubic-bezier(.16,1,.3,1) }
    .reveal.is-in { opacity: 1; transform: none }
    .lag-el { will-change: translate }
    @media (prefers-reduced-motion: reduce) { .reveal { transition: none; opacity: 1; transform: none } }
  </style>

  <script is:inline define:vars={{ variants }}>
    const keys = variants.map(v => v.key);
    const label = document.getElementById('protoLabel');

    function current() {
      const k = new URLSearchParams(location.search).get('variant');
      return keys.includes(k) ? k : 'a';
    }

    function apply(k) {
      document.querySelectorAll('.proto-variant').forEach(el => { el.hidden = el.dataset.key !== k; });
      const v = variants.find(v => v.key === k);
      label.textContent = k.toUpperCase() + ' — ' + v.name;
      const url = new URL(location.href);
      url.searchParams.set('variant', k);
      history.replaceState(null, '', url);
      window.scrollTo(0, 0);
      initAnims();
    }

    function cycle(dir) {
      const i = (keys.indexOf(current()) + dir + keys.length) % keys.length;
      apply(keys[i]);
    }

    document.querySelectorAll('.proto-switcher button').forEach(b =>
      b.addEventListener('click', () => cycle(Number(b.dataset.dir))));

    document.addEventListener('keydown', e => {
      const t = e.target;
      if (t && (t.matches('input, textarea, [contenteditable]'))) return;
      if (e.key === 'ArrowLeft') cycle(-1);
      if (e.key === 'ArrowRight') cycle(1);
    });

    // ── Анимации: reveal + count-up, работают в активном варианте ──
    let io;
    function initAnims() {
      if (io) io.disconnect();
      io = new IntersectionObserver(entries => {
        entries.forEach(en => {
          if (!en.isIntersecting) return;
          en.target.classList.add('is-in');
          if (en.target.dataset.count) countUp(en.target);
          io.unobserve(en.target);
        });
      }, { threshold: 0.15 });
      const active = document.querySelector('.proto-variant:not([hidden])');
      active.querySelectorAll('.reveal, [data-count]').forEach(el => io.observe(el));
      initLag(active);
    }

    // ── Инерционный скролл: элементы подтягиваются за скроллом с запаздыванием ──
    // Скорость скролла сглаживается (lerp), разница даёт смещение через CSS-свойство
    // `translate`, чтобы не конфликтовать с transform у reveal/tilt.
    const lagGroups = [
      ['.va-product', .10], ['.va-bento-cell', .08], ['.va-adv', .07], ['.va-cat-row', .05],
      ['.va-news-row', .05], ['.va-hero-media', .12], ['.va-quote-wrap', .08],
      ['.vb-cat', .10], ['.vb-card', .09], ['.vb-adv', .07], ['.vb-log', .08],
      ['.vb-news', .07], ['.vb-scan-frame', .13], ['.vb-stat', .06],
      ['.vc-cat', .10], ['.vc-product', .09], ['.vc-value', .07], ['.vc-journal-row', .05],
      ['.vc-quote-inner', .09],
    ];
    let lagEls = [];
    let lagRaf = null;

    function initLag(active) {
      lagEls.forEach(({ el }) => { el.style.translate = ''; });
      lagEls = [];
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      lagGroups.forEach(([sel, base]) => {
        active.querySelectorAll(sel).forEach((el, i) => {
          if (el.classList.contains('vc-parallax')) return; // у них свой параллакс
          el.classList.add('lag-el');
          // соседние элементы отстают по-разному — сетка «рассыпается» при скролле
          lagEls.push({ el, k: base * (1 + (i % 4) * 0.45) });
        });
      });
      if (!lagRaf) lagLoop();
    }

    let smoothY = window.scrollY;
    function lagLoop() {
      const y = window.scrollY;
      smoothY += (y - smoothY) * 0.09;
      let delta = y - smoothY;                    // >0 — скроллим вниз
      if (Math.abs(delta) < 0.05) { delta = 0; smoothY = y; }
      delta = Math.max(-260, Math.min(260, delta));
      for (const { el, k } of lagEls) {
        el.style.translate = delta === 0 ? '' : `0 ${(delta * k).toFixed(2)}px`;
      }
      lagRaf = requestAnimationFrame(lagLoop);
    }

    function countUp(el) {
      const target = Number(el.dataset.count);
      const suffix = el.dataset.suffix || '';
      const dur = 1200;
      const t0 = performance.now();
      function tick(t) {
        const p = Math.min((t - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(target * eased) + suffix;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    apply(current());
  </script>
</body>
</html>
