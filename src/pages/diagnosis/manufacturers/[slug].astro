---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductGrid from '../../../components/ProductGrid.astro';
import { getCollection } from 'astro:content';
import { sortProducts } from '../../../lib/productSort';
import { brandSvg, brandLogoMask } from '../../../lib/brandLogo';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map(b => ({
    params: { slug: b.data.slug },
    props: { entry: b },
  }));
}

const { entry } = Astro.props;
const brand = entry.data;
const products = sortProducts(
  (await getCollection('products'))
  .filter(p => p.data.category === 'diagnosis' && p.data.brands.includes(brand.slug))
);

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'Brand',
  name: brand.title,
  ...(brand.description && { description: brand.description }),
  ...(brand.country && { country: brand.country }),
};
---
<BaseLayout
  title={`${brand.title} — оборудование для диагностики`}
  description={brand.description || `Оборудование ${brand.title} для автодиагностики`}
  ogImage="/og-image.png"
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Диагностика', href: '/diagnosis/' },
    { label: brand.title },
  ]}
>
  <div class="brand-heading">
    {brandSvg(brand.slug)
      ? <span class="brand-icon" set:html={brandSvg(brand.slug)} />
      : brandLogoMask(brand.slug) && <span class="brand-icon brand-mask" style={`-webkit-mask-image:url(${brandLogoMask(brand.slug)});mask-image:url(${brandLogoMask(brand.slug)})`} />}
    <h1>{brand.title}</h1>
  </div>
  {brand.description && <p style="color:var(--text2);margin-bottom:1rem">{brand.description}</p>}
  {brand.country && <p style="color:var(--text2);font-size:.85rem;margin-bottom:1.5rem">Страна: {brand.country}</p>}

  {products.length > 0 ? (
    <ProductGrid
      products={products.map(p => ({
        ...p.data,
        category: 'diagnosis',
        slug: p.slug,
      }))}
    />
  ) : (
    <p>Товары данного производителя не найдены</p>
  )}
</BaseLayout>

<style>
  .brand-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .brand-icon {
    display: inline-flex;
    color: var(--text2);
    flex-shrink: 0;
  }
  .brand-icon :global(svg) { width: 48px; height: 48px }
  .brand-icon.brand-mask {
    width: 48px; height: 48px; background-color: currentColor;
    -webkit-mask-size: contain; mask-size: contain;
    -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
    -webkit-mask-position: center; mask-position: center;
  }
  .brand-heading h1 { margin: 0 }
</style>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
