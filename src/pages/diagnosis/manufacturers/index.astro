---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { brandSvg } from '../../../lib/brandLogo';

const brands = (await getCollection('brands')).sort((a, b) => a.data.title.localeCompare(b.data.title));
const diagnosisProducts = (await getCollection('products')).filter(p => p.data.category === 'diagnosis');
const productsByBrand = new Map<string, number>();
for (const p of diagnosisProducts) {
  if (p.data.brand) productsByBrand.set(p.data.brand, (productsByBrand.get(p.data.brand) || 0) + 1);
}

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Производители диагностического оборудования',
  description: 'Оригинальное диагностическое оборудование по производителям',
  url: `${siteUrl}/diagnosis/manufacturers/`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: brands.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: { '@type': 'Brand', name: b.data.title, url: `${siteUrl}/diagnosis/manufacturers/${b.data.slug}/` },
    })),
  },
};
---

<BaseLayout
  title="Производители диагностического оборудования"
  description="Оригинальное диагностическое оборудование по производителям"
  ogImage="/og-image.png"
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Диагностика', href: '/diagnosis/' },
    { label: 'Производители' },
  ]}
>
  <h1>Производители</h1>
  <p style="color:var(--text2);margin-bottom:1.5rem">Диагностическое оборудование по производителям автомобилей</p>

  <div class="brands-grid">
    {brands.map(b => {
      const count = productsByBrand.get(b.data.slug) || 0;
      return (
        <a href={`/diagnosis/manufacturers/${b.data.slug}/`} class="brand-card">
          {brandSvg(b.data.slug) && <span class="brand-logo" set:html={brandSvg(b.data.slug)} />}
          <span class="brand-title">{b.data.title}</span>
          {count > 0 && <span class="brand-count">{count} товар{count > 1 ? 'ов' : ''}</span>}
        </a>
      );
    })}
  </div>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />

<style>
  .brands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }
  .brand-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-align: center;
    transition: border-color .2s;
  }
  .brand-card:hover {
    border-color: var(--accent);
  }
  .brand-logo {
    display: inline-flex;
    color: var(--text2);
  }
  .brand-logo :global(svg) { width: 34px; height: 34px }
  .brand-card:hover .brand-logo { color: var(--text) }
  .brand-title {
    font-size: .9rem;
    color: var(--text);
  }
  .brand-count {
    font-size: .75rem;
    color: var(--text2);
  }
</style>
