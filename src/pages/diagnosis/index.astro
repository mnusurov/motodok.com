---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import { sortProducts } from '../../lib/productSort';
import { brandSvg } from '../../lib/brandLogo';
import { svg, catIcon } from '../../lib/icons';

const category = (await getCollection('categories')).find(c => c.data.slug === 'diagnosis');
const products = sortProducts(
  (await getCollection('products'))
  .filter(p => p.data.category === 'diagnosis')
);

const brands = (await getCollection('brands')).sort((a, b) => a.data.title.localeCompare(b.data.title));
const productsByBrand = new Map<string, number>();
for (const p of products) {
  if (p.data.brand) productsByBrand.set(p.data.brand, (productsByBrand.get(p.data.brand) || 0) + 1);
}

const siteUrl = 'https://motodok.com';
const ld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: category?.data.title || 'Диагностика',
  description: category?.data.description || 'Оборудование для автодиагностики',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: { '@type': 'Product', name: p.data.title, url: `${siteUrl}/diagnosis/${p.slug}/` },
    })),
  },
};
---

<BaseLayout
  title={category?.data.metaTitle || category?.data.title || 'Диагностика'}
  description={category?.data.metaDescription || category?.data.description || 'Оборудование для автодиагностики'}
  ogImage={category?.data.image}
  breadcrumbs={[ { label: 'Главная', href: '/' }, { label: 'Диагностика' } ]}
>
  <PageHeader title={category?.data.title || 'Диагностика'} lead={category?.data.description} icon={svg(catIcon.diagnosis, 28)} />

  {brands.some(b => productsByBrand.get(b.data.slug)) && (
    <section class="brands-section">
      <h2>Производители</h2>
      <div class="brands-grid">
        {brands.filter(b => productsByBrand.get(b.data.slug)).map(b => (
          <a href={`/diagnosis/manufacturers/${b.data.slug}/`} class="brand-card">
            {brandSvg(b.data.slug) && <span class="brand-logo" set:html={brandSvg(b.data.slug)} />}
            <span class="brand-title">{b.data.title}</span>
            <span class="brand-count">{productsByBrand.get(b.data.slug)}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <ProductGrid
    products={products.map(p => ({
      ...p.data,
      category: 'diagnosis',
      slug: p.slug,
    }))}
  />
</BaseLayout>

<style>
  .brands-section { margin-bottom: 2rem }
  .brands-section h2 { font-size: 1.2rem; margin-bottom: .75rem }
  .brands-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: .75rem }
  .brand-card {
    display: flex; flex-direction: column; align-items: center;
    gap: .4rem; padding: .75rem .5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: .85rem; text-align: center;
    transition: border-color .2s;
  }
  .brand-card:hover { border-color: var(--accent) }
  .brand-logo { display: inline-flex; color: var(--text2) }
  .brand-logo :global(svg) { width: 36px; height: 36px }
  .brand-card:hover .brand-logo { color: var(--text) }
  .brand-title { color: var(--text); line-height: 1.2 }
  .brand-count {
    font-size: .75rem; color: var(--text2);
    background: var(--bg2); padding: 1px 6px; border-radius: 8px;
    margin-top: auto;
  }
</style>

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
