---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles')).sort(
  (a, b) => (b.data.publishedDate?.getTime() || 0) - (a.data.publishedDate?.getTime() || 0)
);
---
<BaseLayout
  title="Статьи — Motodok"
  description="Полезные статьи по автодиагностике, ремонту электроники, выбору оборудования"
  breadcrumbs={[
    { label: 'Главная', href: '/' },
    { label: 'Статьи' },
  ]}
>
  <h1>Статьи</h1>

  {allArticles.length > 0 ? (
    <div class="articles-grid">
      {allArticles.map(item => (
        <article class="article-card">
          <a href={`/Articles/${item.slug}/`} class="article-card-link">
            {item.data.image && <img src={item.data.image} alt={item.data.title} loading="lazy" class="article-card-img" />}
            <div class="article-card-body">
              {item.data.publishedDate && <time class="article-card-date">{item.data.publishedDate.toLocaleDateString('ru-RU')}</time>}
              <h2 class="article-card-title">{item.data.title}</h2>
              <p class="article-card-desc">{item.data.description}</p>
              {item.data.tags && item.data.tags.length > 0 && (
                <div class="article-card-tags">
                  {item.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  ) : (
    <p>Статьи скоро появятся</p>
  )}
</BaseLayout>

<style>
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .article-card {
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .article-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .article-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .article-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .article-card-body {
    padding: 0.75rem;
  }
  .article-card-date {
    font-size: 0.8rem;
    color: #999;
  }
  .article-card-title {
    margin: 0.25rem 0;
    font-size: 1.1rem;
  }
  .article-card-desc {
    font-size: 0.85rem;
    color: #666;
    margin: 0 0 0.5rem;
  }
  .article-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .tag {
    font-size: 0.75rem;
    background: #f0f0f0;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    color: #666;
  }
</style>
