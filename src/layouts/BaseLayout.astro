---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';

export interface Props {
  title: string;
  description?: string;
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  breadcrumbs?: { label: string; href?: string }[];
  noIndex?: boolean;
  wide?: boolean;
}

const { title, description, metaTitle, metaDescription, ogImage, ogType, canonical, noIndex, breadcrumbs, wide } = Astro.props;
const fallbackOgImage = '/og-image.png';
const generatedDescription = metaDescription || description || `${title} — Motodok. Оборудование для диагностики и ремонта автомобилей.`;
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={metaTitle || title}
    description={generatedDescription}
    ogImage={ogImage || fallbackOgImage}
    ogType={ogType}
    canonical={canonical}
    noIndex={noIndex}
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-8KFSGR4BFQ"></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-8KFSGR4BFQ');
      </script>
      <script is:inline>
        (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
        (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

        ym(110876860, "init", {
          clickmap: true,
          trackLinks: true,
          accurateTrackBounce: true,
          webvisor: true
        });
      </script>
    </>
  )}
</head>
<body>
  {import.meta.env.PROD && (
    <noscript><div><img src="https://mc.yandex.ru/watch/110876860" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
  )}
  <div class="layout">
    <Header />
    {breadcrumbs && breadcrumbs.length > 0 && (
      <>
        <BreadcrumbJsonLd items={breadcrumbs} />
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <div class="container">
            {breadcrumbs.map((crumb, i) => (
              i < breadcrumbs.length - 1
                ? <><a href={crumb.href || '#'}>{crumb.label}</a><span class="sep">/</span></>
                : <span class="current" aria-current="page">{crumb.label}</span>
            ))}
          </div>
        </nav>
      </>
    )}
    <main>
      {wide ? <slot /> : <div class="container page-content"><slot /></div>}
    </main>
    <Footer />
  </div>
</body>
</html>
