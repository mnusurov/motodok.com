---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';

export interface Props {
  title: string;
  description?: string;
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  breadcrumbs?: { label: string; href?: string }[];
  noIndex?: boolean;
}

const { title, description, metaTitle, metaDescription, ogImage, ogType, canonical, noIndex, breadcrumbs } = Astro.props;
const fallbackOgImage = '/og-image.png';
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={metaTitle || title}
    description={metaDescription || description}
    ogImage={ogImage || fallbackOgImage}
    ogType={ogType}
    canonical={canonical}
    noIndex={noIndex}
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body>
  <div class="layout">
    <Header />
    {breadcrumbs && breadcrumbs.length > 0 && (
      <>
        <BreadcrumbJsonLd items={breadcrumbs} />
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <div class="container">
            {breadcrumbs.map((crumb, i) => (
              i < breadcrumbs.length - 1
                ? <><a href={crumb.href || '#'}>{crumb.label}</a><span class="sep">/</span></>
                : <span class="current" aria-current="page">{crumb.label}</span>
            ))}
          </div>
        </nav>
      </>
    )}
    <main>
      <div class="container page-content">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>&copy; 2007-2026 <a href="/">Motodok</a> &middot; г. Бишкек, Кыргызстан</p>
        <p class="footer-contacts">+996 (772) 553-731 &middot; +996 (312) 298-969</p>
      </div>
    </footer>
  </div>
</body>
</html>
