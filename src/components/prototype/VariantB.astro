---
export interface Props {
  categories: { title: string; slug: string; description?: string }[];
  products: { title: string; slug: string; category: string; price?: string }[];
}

const { categories, products } = Astro.props;
const categorySlugMap: Record<string, string> = {
  diagnosis: 'Diagnosis', measure: 'Measure', immobilizer: 'Immobilizer',
  odometers: 'Odometers', databases: 'Databases',
};
const sample = products.slice(0, 12);
---

<div class="vb">
  <header class="vb-header">
    <div class="vb-header-inner">
      <div class="vb-header-left">
        <a href="/" class="vb-logo">Motodok</a>
        <nav class="vb-nav">
          <a href="/Diagnosis/">Диагностика</a>
          <a href="/Measure/">Измерение</a>
          <a href="/Immobilizer/">Иммобилайзеры</a>
          <a href="/Odometers/">Одометры</a>
          <a href="/Databases/">Базы данных</a>
          <a href="/Services/">Услуги</a>
          <a href="/Articles/">Статьи</a>
        </nav>
      </div>
      <div class="vb-header-right">
        <a href="/Prices/" class="vb-nav-link">Цены</a>
        <a href="/Contacts/" class="vb-nav-link">Контакты</a>
        <a href="tel:+996772553731" class="vb-phone">+996-772-553-731</a>
      </div>
    </div>
  </header>

  <div class="vb-page">
    <aside class="vb-sidebar">
      <h3>Категории</h3>
      <nav>
        {categories.sort((a, b) => a.data.order - b.data.order).map(c => {
          const slug = categorySlugMap[c.data.slug] || c.data.slug;
          return <a href={`/${slug}/`}>{c.data.title}</a>;
        })}
      </nav>
      <div class="vb-sidebar-contact">
        <h4>Контакты</h4>
        <p><a href="tel:+996772553731">+996-772-553-731</a></p>
        <p><a href="mailto:info@motodok.com">info@motodok.com</a></p>
      </div>
    </aside>

    <main class="vb-main">
      <section class="vb-hero">
        <div class="vb-hero-text">
          <span class="vb-badge">Оборудование для диагностики</span>
          <h1>Профессиональные инструменты для автосервиса</h1>
          <p>Сканеры, осциллографы, иммобилайзеры и оборудование для ремонта ЭБУ с доставкой по всему Кыргызстану</p>
          <div class="vb-hero-actions">
            <a href="/Diagnosis/" class="vb-btn">Перейти в каталог</a>
          </div>
        </div>
        <div class="vb-hero-illus">
          <div class="vb-illus-shape"></div>
        </div>
      </section>

      <section class="vb-categories">
        <h2>Категории</h2>
        <div class="vb-cat-list">
          {categories.sort((a, b) => a.data.order - b.data.order).map((c, i) => {
            const slug = categorySlugMap[c.data.slug] || c.data.slug;
            return (
              <a href={`/${slug}/`} class="vb-cat-item">
                <span class="vb-cat-num">{(i + 1).toString().padStart(2, '0')}</span>
                <div class="vb-cat-info">
                  <h3>{c.data.title}</h3>
                  <p>{c.data.description?.slice(0, 90)}</p>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      {sample.length > 0 && (
        <section class="vb-products">
          <h2>Товары</h2>
          <div class="vb-prod-grid">
            {sample.map(p => {
              const cat = categorySlugMap[p.category] || p.category;
              return (
                <a href={`/${cat}/${p.slug}/`} class="vb-prod-item">
                  <div class="vb-prod-top">
                    <span class="vb-prod-cat">{p.category}</span>
                    <span class="vb-prod-price">{p.price} $</span>
                  </div>
                  <h3>{p.title}</h3>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </main>
  </div>

  <footer class="vb-footer">
    <div class="vb-footer-inner">
      <p>&copy; 2024 Motodok. Все права защищены.</p>
      <p>Телефон: <a href="tel:+996772553731">+996-772-553-731</a></p>
      <p><a href="/admin">CMS</a></p>
    </div>
  </footer>
</div>

<style>
  .vb {
    --accent: #0891b2;
    --accent-light: #ecfeff;
    --text: #1e293b;
    --muted: #64748b;
    --border: #e2e8f0;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: #fff; color: var(--text); line-height: 1.5; min-height: 100vh;
  }
  .vb * { margin: 0; box-sizing: border-box; }
  .vb a { color: inherit; text-decoration: none; }

  .vb-header { border-bottom: 1px solid var(--border); background: #fff; position: sticky; top: 0; z-index: 100; }
  .vb-header-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 24px; height: 56px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .vb-header-left { display: flex; align-items: center; gap: 32px; }
  .vb-header-right { display: flex; align-items: center; gap: 16px; }
  .vb-logo { font-size: 1.25rem; font-weight: 700; color: var(--accent); }
  .vb-nav { display: flex; gap: 2px; }
  .vb-nav a, .vb-nav-link {
    padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; color: var(--muted);
  }
  .vb-nav a:hover, .vb-nav-link:hover { background: #f1f5f9; color: var(--text); }
  .vb-phone { font-weight: 600; font-size: 0.9rem; color: var(--accent); }

  .vb-page { display: flex; max-width: 1200px; margin: 0 auto; min-height: calc(100vh - 56px); }

  .vb-sidebar {
    width: 200px; flex-shrink: 0; padding: 32px 16px 32px 24px;
    border-right: 1px solid var(--border);
  }
  .vb-sidebar h3 { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 12px; }
  .vb-sidebar nav { display: flex; flex-direction: column; gap: 2px; margin-bottom: 24px; }
  .vb-sidebar nav a {
    padding: 6px 8px; border-radius: 4px; font-size: 0.85rem;
    color: var(--text); transition: background 0.1s;
  }
  .vb-sidebar nav a:hover { background: #f1f5f9; }
  .vb-sidebar-contact h4 { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 8px; }
  .vb-sidebar-contact p { font-size: 0.85rem; margin-bottom: 4px; }

  .vb-main { flex: 1; padding: 32px 24px; }

  .vb-hero {
    display: flex; gap: 48px; align-items: center; margin-bottom: 56px;
    background: linear-gradient(135deg, var(--accent-light) 0%, #fff 100%);
    border-radius: 16px; padding: 40px;
  }
  .vb-hero-text { flex: 1; }
  .vb-badge {
    display: inline-block; padding: 4px 10px; border-radius: 999px;
    background: var(--accent); color: #fff; font-size: 0.75rem; font-weight: 600;
    margin-bottom: 16px;
  }
  .vb-hero h1 { font-size: 2rem; font-weight: 700; line-height: 1.2; margin-bottom: 12px; }
  .vb-hero p { font-size: 1rem; color: var(--muted); line-height: 1.6; margin-bottom: 24px; }
  .vb-btn {
    display: inline-block; padding: 10px 24px; border-radius: 8px;
    background: var(--accent); color: #fff; font-weight: 600; font-size: 0.9rem;
  }
  .vb-btn:hover { background: #0e7490; }
  .vb-hero-illus { width: 160px; height: 160px; flex-shrink: 0; }
  .vb-illus-shape {
    width: 100%; height: 100%; border-radius: 24px;
    background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
    opacity: 0.15; transform: rotate(12deg);
  }

  .vb-categories { margin-bottom: 48px; }
  .vb-categories h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 24px; }
  .vb-cat-list { display: flex; flex-direction: column; gap: 8px; }
  .vb-cat-item {
    display: flex; align-items: center; gap: 20px;
    padding: 16px 20px; border: 1px solid var(--border); border-radius: 12px;
    transition: all 0.15s;
  }
  .vb-cat-item:hover { border-color: var(--accent); background: var(--accent-light); }
  .vb-cat-num { font-size: 1.5rem; font-weight: 700; color: var(--accent); width: 40px; opacity: 0.5; }
  .vb-cat-info h3 { font-size: 1rem; font-weight: 600; margin-bottom: 4px; }
  .vb-cat-info p { font-size: 0.85rem; color: var(--muted); }

  .vb-products h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 24px; }
  .vb-prod-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 8px; }
  .vb-prod-item {
    display: block; padding: 16px; border: 1px solid var(--border); border-radius: 8px;
    transition: all 0.15s;
  }
  .vb-prod-item:hover { border-color: var(--accent); box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
  .vb-prod-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .vb-prod-cat { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .vb-prod-price { font-size: 0.95rem; font-weight: 700; color: var(--accent); }
  .vb-prod-item h3 { font-size: 0.9rem; font-weight: 500; color: var(--text); }

  .vb-footer {
    border-top: 1px solid var(--border); background: #f8fafc; padding: 24px;
  }
  .vb-footer-inner {
    max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between;
    font-size: 0.85rem; color: var(--muted);
  }
  .vb-footer a { color: var(--accent); }
</style>
