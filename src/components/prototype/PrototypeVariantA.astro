---
// PROTOTYPE Variant A — «Инженерный монохром»: светлая швейцарская типографика,
// ультрамариновый акцент, моноширинные подписи, категории списком, bento-статистика.
const { showcase, categories, brands, news, stats, advantages, testimonials } = Astro.props;
const hero = showcase[0];
---

<div class="va">
  <header class="va-header">
    <a class="va-logo" href="#">MOTODOK<sup>®</sup></a>
    <nav>
      <a href="#">Каталог</a><a href="#">Приборы</a><a href="#">Базы данных</a><a href="#">Статьи</a><a href="#">Контакты</a>
    </nav>
    <a class="va-header-cta" href="#">+996 772 553-731</a>
  </header>

  <section class="va-hero">
    <div class="va-hero-grid">
      <div class="va-hero-text">
        <p class="va-mono">Автодиагностика — с 2007 года / Бишкек → СНГ</p>
        <h1>Оборудование, которому доверяют <em>диагносты</em></h1>
        <p class="va-sub">Дилерские сканеры, осциллографы, программаторы и базы данных. Проверяем каждый прибор перед отправкой.</p>
        <div class="va-cta-row">
          <a class="va-btn" href="#">Смотреть каталог <span>&rarr;</span></a>
          <a class="va-btn va-btn-ghost" href="#">Подобрать прибор</a>
        </div>
      </div>
      <div class="va-hero-media reveal">
        <div class="va-frame">
          <span class="va-corner tl"></span><span class="va-corner tr"></span><span class="va-corner bl"></span><span class="va-corner br"></span>
          <img src={hero.image} alt={hero.title} loading="eager" />
        </div>
        <p class="va-mono va-caption">fig. 01 — {hero.title} / ${hero.price}</p>
      </div>
    </div>
  </section>

  <div class="va-marquee" aria-hidden="true">
    <div class="va-marquee-track">
      {[...brands, ...brands].map(b => (
        <span class="va-brand">{b.logo ? <Fragment set:html={b.logo} /> : b.title}</span>
      ))}
    </div>
  </div>

  <section class="va-section">
    <div class="va-section-head reveal">
      <span class="va-mono">01 / Каталог</span>
      <h2>Категории</h2>
    </div>
    <div class="va-cat-list">
      {categories.map((c, i) => (
        <a class="va-cat-row reveal" href={c.href} style={`transition-delay:${i * 60}ms`}>
          <span class="va-mono va-cat-num">0{i + 1}</span>
          <span class="va-cat-title">{c.title}</span>
          <span class="va-mono va-cat-count">{c.count} поз.</span>
          <span class="va-cat-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="va-section">
    <div class="va-bento">
      <div class="va-bento-cell va-bento-big reveal">
        <span class="va-stat-num" data-count={stats[0].number} data-suffix={stats[0].suffix}>0</span>
        <span class="va-stat-label">{stats[0].label}</span>
      </div>
      {stats.slice(1).map((s, i) => (
        <div class="va-bento-cell reveal" style={`transition-delay:${i * 80}ms`}>
          <span class="va-stat-num" data-count={s.number} data-suffix={s.suffix}>0</span>
          <span class="va-stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="va-section">
    <div class="va-section-head reveal">
      <span class="va-mono">02 / Витрина</span>
      <h2>Флагманские приборы</h2>
    </div>
    <div class="va-products">
      {showcase.slice(0, 8).map((p, i) => (
        <a class="va-product reveal" href={p.href} style={`transition-delay:${(i % 4) * 60}ms`}>
          <div class="va-product-img"><img src={p.image} alt={p.title} loading="lazy" /></div>
          <div class="va-product-meta">
            <span class="va-product-title">{p.title}</span>
            <span class="va-mono va-product-price">${p.price}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="va-section">
    <div class="va-section-head reveal">
      <span class="va-mono">03 / Принципы</span>
      <h2>Почему Motodok</h2>
    </div>
    <div class="va-adv-grid">
      {advantages.map((a, i) => (
        <div class="va-adv reveal" style={`transition-delay:${(i % 3) * 70}ms`}>
          <span class="va-mono va-adv-num">0{i + 1}</span>
          <h3>{a.title}</h3>
          <p>{a.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="va-section va-quote-section">
    <div class="va-quote-wrap reveal">
      <span class="va-quote-mark">&ldquo;</span>
      {testimonials.map((t, i) => (
        <blockquote class="va-quote" data-idx={i} hidden={i !== 0}>
          <p>{t.text}</p>
          <footer><strong>{t.name}</strong> — {t.role}</footer>
        </blockquote>
      ))}
      <div class="va-quote-nav">
        <button type="button" class="va-quote-btn" data-q-dir="-1" aria-label="Предыдущий отзыв">&larr;</button>
        <button type="button" class="va-quote-btn" data-q-dir="1" aria-label="Следующий отзыв">&rarr;</button>
      </div>
    </div>
  </section>

  <section class="va-section">
    <div class="va-section-head reveal">
      <span class="va-mono">04 / Журнал</span>
      <h2>Статьи и новости</h2>
    </div>
    <div class="va-news">
      {news.map((n, i) => (
        <a class="va-news-row reveal" href={n.href} style={`transition-delay:${i * 60}ms`}>
          <span class="va-mono">{n.dateStr} · {n.type}</span>
          <span class="va-news-title">{n.title}</span>
          <span class="va-cat-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="va-final reveal">
    <h2>Подберём оборудование под ваш автопарк</h2>
    <p class="va-mono">Консультация бесплатно / ответ в течение часа</p>
    <a class="va-btn va-btn-invert" href="#">Связаться <span>&rarr;</span></a>
  </section>

  <footer class="va-footer">
    <span class="va-mono">© 2007–2026 Motodok</span>
    <span class="va-mono">Бишкек, Кыргызстан</span>
    <span class="va-mono">+996 772 553-731</span>
  </footer>
</div>

<style>
  .va {
    --ink: #141412;
    --paper: #f4f3ee;
    --line: #d8d6cd;
    --blue: #2337ff;
    font-family: 'Space Grotesk', 'Manrope', sans-serif;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.55;
  }
  .va-mono { font-family: 'JetBrains Mono', monospace; font-size: .75rem; text-transform: uppercase; letter-spacing: .08em; color: #6b6a63 }

  .va-header {
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    padding: 0 clamp(1rem, 4vw, 3rem); height: 68px;
    border-bottom: 1px solid var(--ink);
    position: sticky; top: 0; background: var(--paper); z-index: 50;
  }
  .va-logo { font-weight: 700; font-size: 1.15rem; letter-spacing: -.01em }
  .va-logo sup { color: var(--blue); font-size: .6em }
  .va-header nav { display: flex; gap: 1.6rem }
  .va-header nav a { font-size: .9rem; position: relative }
  .va-header nav a::after { content: ''; position: absolute; left: 0; bottom: -4px; width: 0; height: 2px; background: var(--blue); transition: width .25s }
  .va-header nav a:hover::after { width: 100% }
  .va-header-cta { font-family: 'JetBrains Mono', monospace; font-size: .85rem; border: 1px solid var(--ink); padding: .45rem .9rem; border-radius: 999px; transition: all .2s }
  .va-header-cta:hover { background: var(--ink); color: var(--paper) }

  .va-hero { padding: clamp(3rem, 7vw, 6rem) clamp(1rem, 4vw, 3rem); border-bottom: 1px solid var(--ink);
    background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 64px 64px; }
  .va-hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(2rem, 5vw, 5rem); align-items: center; max-width: 1280px; margin: 0 auto }
  .va-hero h1 { font-size: clamp(2.4rem, 5.5vw, 4.6rem); line-height: 1.03; letter-spacing: -.03em; font-weight: 700; margin: 1.2rem 0 }
  .va-hero h1 em { font-style: normal; color: var(--blue) }
  .va-sub { font-size: 1.1rem; max-width: 34rem; color: #45443f }
  .va-cta-row { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap }
  .va-btn { display: inline-flex; align-items: center; gap: .6rem; background: var(--ink); color: var(--paper);
    padding: .9rem 1.6rem; border-radius: 999px; font-weight: 500; transition: background .2s, transform .2s }
  .va-btn:hover { background: var(--blue); transform: translateY(-2px) }
  .va-btn span { transition: transform .2s } .va-btn:hover span { transform: translateX(4px) }
  .va-btn-ghost { background: transparent; color: var(--ink); border: 1px solid var(--ink) }
  .va-btn-ghost:hover { background: var(--ink); color: var(--paper) }
  .va-btn-invert { background: var(--paper); color: var(--ink) }
  .va-btn-invert:hover { background: #fff; transform: translateY(-2px) }

  .va-hero-media { justify-self: center; width: 100% }
  .va-frame { position: relative; background: #fff; border: 1px solid var(--ink); padding: 2rem; display: flex; justify-content: center }
  .va-frame img { max-height: 320px; object-fit: contain; mix-blend-mode: multiply }
  .va-corner { position: absolute; width: 14px; height: 14px; border: 2px solid var(--blue) }
  .va-corner.tl { top: -7px; left: -7px; border-right: 0; border-bottom: 0 }
  .va-corner.tr { top: -7px; right: -7px; border-left: 0; border-bottom: 0 }
  .va-corner.bl { bottom: -7px; left: -7px; border-right: 0; border-top: 0 }
  .va-corner.br { bottom: -7px; right: -7px; border-left: 0; border-top: 0 }
  .va-caption { margin-top: .8rem; text-align: center }

  .va-marquee { overflow: hidden; border-bottom: 1px solid var(--ink); padding: 1.1rem 0; background: #fff }
  .va-marquee-track { display: flex; gap: 4rem; width: max-content; animation: va-scroll 34s linear infinite }
  .va-brand { font-family: 'JetBrains Mono', monospace; font-size: .95rem; text-transform: uppercase; letter-spacing: .12em; color: #45443f; display: inline-flex; align-items: center }
  .va-brand :global(svg) { height: 26px; width: auto; opacity: .7 }
  @keyframes va-scroll { to { transform: translateX(-50%) } }

  .va-section { padding: clamp(3rem, 6vw, 5.5rem) clamp(1rem, 4vw, 3rem); max-width: 1280px; margin: 0 auto }
  .va-section-head { display: flex; flex-direction: column; gap: .5rem; margin-bottom: 2.5rem }
  .va-section h2 { font-size: clamp(1.8rem, 3.4vw, 2.8rem); letter-spacing: -.02em; font-weight: 700 }

  .va-cat-list { border-top: 1px solid var(--ink) }
  .va-cat-row { display: grid; grid-template-columns: 4rem 1fr auto 3rem; align-items: center; gap: 1.5rem;
    padding: 1.6rem .5rem; border-bottom: 1px solid var(--ink); transition: background .25s, color .25s, padding-left .25s }
  .va-cat-title { font-size: clamp(1.3rem, 2.4vw, 2rem); font-weight: 500; letter-spacing: -.01em }
  .va-cat-arrow { font-size: 1.4rem; transition: transform .25s }
  .va-cat-row:hover { background: var(--blue); color: #fff; padding-left: 1.4rem }
  .va-cat-row:hover .va-mono { color: rgba(255,255,255,.7) }
  .va-cat-row:hover .va-cat-arrow { transform: translateX(6px) }

  .va-bento { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--ink); border: 1px solid var(--ink) }
  .va-bento-cell { background: var(--paper); padding: 2.2rem; display: flex; flex-direction: column; gap: .4rem }
  .va-bento-big { grid-row: span 1; background: #fff }
  .va-stat-num { font-size: clamp(2.4rem, 4.5vw, 3.6rem); font-weight: 700; letter-spacing: -.03em; color: var(--blue); font-variant-numeric: tabular-nums }
  .va-stat-label { color: #6b6a63 }

  .va-products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem }
  .va-product { border: 1px solid var(--line); background: #fff; transition: border-color .2s, transform .25s, box-shadow .25s }
  .va-product:hover { border-color: var(--ink); transform: translateY(-6px); box-shadow: 0 18px 40px -20px rgba(20,20,18,.35) }
  .va-product-img { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; padding: 1.4rem; border-bottom: 1px solid var(--line) }
  .va-product-img img { max-height: 100%; object-fit: contain; mix-blend-mode: multiply }
  .va-product-meta { padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: .5rem }
  .va-product-title { font-weight: 500; font-size: .95rem; line-height: 1.35 }
  .va-product-price { color: var(--blue); font-size: .95rem }

  .va-adv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem 3rem }
  .va-adv { border-top: 2px solid var(--ink); padding-top: 1.2rem }
  .va-adv-num { color: var(--blue) }
  .va-adv h3 { margin: .6rem 0 .5rem; font-size: 1.15rem; font-weight: 700 }
  .va-adv p { color: #45443f; font-size: .95rem }

  .va-quote-section { text-align: center }
  .va-quote-wrap { max-width: 820px; margin: 0 auto; position: relative }
  .va-quote-mark { font-size: 6rem; line-height: 0; color: var(--blue); font-family: Georgia, serif; display: block; margin-bottom: 2rem }
  .va-quote p { font-size: clamp(1.25rem, 2.4vw, 1.7rem); line-height: 1.45; letter-spacing: -.01em; font-weight: 500 }
  .va-quote footer { margin-top: 1.4rem; color: #6b6a63; font-size: .95rem }
  .va-quote-nav { margin-top: 2rem; display: flex; gap: .8rem; justify-content: center }
  .va-quote-btn { width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--ink); background: none; font-size: 1.1rem; transition: all .2s }
  .va-quote-btn:hover { background: var(--ink); color: var(--paper) }

  .va-news { border-top: 1px solid var(--ink) }
  .va-news-row { display: grid; grid-template-columns: 15rem 1fr 3rem; gap: 1.5rem; align-items: center;
    padding: 1.3rem .5rem; border-bottom: 1px solid var(--line); transition: padding-left .25s }
  .va-news-title { font-weight: 500; font-size: 1.05rem }
  .va-news-row:hover { padding-left: 1.2rem } .va-news-row:hover .va-news-title { color: var(--blue) }

  .va-final { background: var(--blue); color: #fff; text-align: center; padding: clamp(4rem, 8vw, 7rem) 1.5rem; max-width: none }
  .va-final h2 { font-size: clamp(2rem, 4.5vw, 3.4rem); letter-spacing: -.02em; max-width: 22ch; margin: 0 auto 1rem }
  .va-final .va-mono { color: rgba(255,255,255,.75); display: block; margin-bottom: 2.2rem }

  .va-footer { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding: 1.6rem clamp(1rem, 4vw, 3rem); border-top: 1px solid var(--ink) }

  @media (max-width: 900px) {
    .va-header nav { display: none }
    .va-hero-grid { grid-template-columns: 1fr }
    .va-bento, .va-products { grid-template-columns: repeat(2, 1fr) }
    .va-adv-grid { grid-template-columns: 1fr }
    .va-news-row { grid-template-columns: 1fr 3rem } .va-news-row .va-mono { grid-column: 1 / -1 }
    .va-cat-row { grid-template-columns: 2.5rem 1fr auto 2rem; gap: .8rem }
  }
</style>

<script is:inline>
  // ротация цитат варианта A
  (function () {
    const wrap = document.querySelector('.va-quote-wrap');
    if (!wrap) return;
    const quotes = wrap.querySelectorAll('.va-quote');
    let idx = 0;
    wrap.querySelectorAll('[data-q-dir]').forEach(btn => btn.addEventListener('click', () => {
      idx = (idx + Number(btn.dataset.qDir) + quotes.length) % quotes.length;
      quotes.forEach((q, i) => { q.hidden = i !== idx; });
    }));
  })();
</script>
