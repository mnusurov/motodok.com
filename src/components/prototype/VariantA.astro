---
export interface Props {
  categories: { title: string; slug: string; description?: string }[];
  products: { title: string; slug: string; category: string; price?: string; features?: string[] }[];
}

const { categories, products } = Astro.props;
const categorySlugMap: Record<string, string> = {
  diagnosis: 'Diagnosis', measure: 'Measure', immobilizer: 'Immobilizer',
  odometers: 'Odometers', databases: 'Databases',
};
const sample = products.slice(0, 8);
---

<div class="va">
  <header class="va-header">
    <div class="va-header-inner">
      <a href="/" class="va-logo">Motodok</a>
      <nav class="va-nav">
        <a href="/Diagnosis/">Диагностика</a>
        <a href="/Measure/">Измерение</a>
        <a href="/Immobilizer/">Иммобилайзеры</a>
        <a href="/Odometers/">Одометры</a>
        <a href="/Databases/">Базы данных</a>
        <a href="/Services/">Услуги</a>
        <a href="/Articles/">Статьи</a>
        <a href="/Contacts/">Контакты</a>
      </nav>
      <a href="tel:+996772553731" class="va-phone">+996-772-553-731</a>
    </div>
  </header>

  <section class="va-hero">
    <div class="va-hero-bg"></div>
    <div class="va-hero-content">
      <h1>Оборудование для автодиагностики</h1>
      <p>Профессиональные сканеры, осциллографы, иммобилайзеры и оборудование для ремонта ЭБУ</p>
      <div class="va-hero-actions">
        <a href="/Diagnosis/" class="va-btn va-btn-primary">Каталог</a>
        <a href="/Services/" class="va-btn va-btn-secondary">Услуги</a>
      </div>
    </div>
  </section>

  <section class="va-categories">
    <div class="va-section-inner">
      <h2 class="va-section-title">Категории</h2>
      <div class="va-cat-grid">
        {categories.sort((a, b) => a.data.order - b.data.order).map(c => {
          const slug = categorySlugMap[c.data.slug] || c.data.slug;
          return (
            <a href={`/${slug}/`} class="va-cat-card">
              <div class="va-cat-icon">{c.data.title[0]}</div>
              <h3>{c.data.title}</h3>
              <p>{c.data.description?.slice(0, 80)}...</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {sample.length > 0 && (
    <section class="va-products">
      <div class="va-section-inner">
        <h2 class="va-section-title">Товары</h2>
        <div class="va-prod-grid">
          {sample.map(p => {
            const cat = categorySlugMap[p.category] || p.category;
            return (
              <a href={`/${cat}/${p.slug}/`} class="va-prod-card">
                <div class="va-prod-card-body">
                  <h3>{p.title}</h3>
                  {p.price && <span class="va-price">{p.price} $</span>}
                  {p.features && <ul>{p.features.slice(0, 2).map(f => <li>{f}</li>)}</ul>}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <footer class="va-footer">
    <div class="va-section-inner">
      <div class="va-footer-grid">
        <div>
          <h4>Motodok</h4>
          <p>Оборудование для автодиагностики с 2015 года</p>
        </div>
        <div>
          <h4>Контакты</h4>
          <p><a href="tel:+996772553731">+996-772-553-731</a></p>
          <p><a href="mailto:info@motodok.com">info@motodok.com</a></p>
        </div>
        <div>
          <h4>Разделы</h4>
          <p><a href="/Diagnosis/">Диагностика</a></p>
          <p><a href="/Services/">Услуги</a></p>
          <p><a href="/Articles/">Статьи</a></p>
        </div>
      </div>
      <div class="va-footer-bottom">&copy; Motodok</div>
    </div>
  </footer>
</div>

<style>
  .va {
    --bg: #0a0a0f;
    --surface: #141420;
    --accent: #f59e0b;
    --text: #e4e4e7;
    --muted: #71717a;
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg); color: var(--text); line-height: 1.5;
  }
  .va * { margin: 0; box-sizing: border-box; }
  .va a { color: inherit; text-decoration: none; }
  .va-section-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .va-section-title { font-size: 1.75rem; font-weight: 700; margin-bottom: 2rem; color: #fff; }

  .va-header { background: var(--surface); border-bottom: 1px solid rgba(255,255,255,0.06); }
  .va-header-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 24px; height: 60px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .va-logo { font-size: 1.5rem; font-weight: 800; color: var(--accent); letter-spacing: -0.02em; }
  .va-nav { display: flex; gap: 4px; }
  .va-nav a {
    padding: 6px 14px; border-radius: 6px; font-size: 0.85rem; color: var(--muted);
    transition: all 0.15s;
  }
  .va-nav a:hover { background: rgba(255,255,255,0.06); color: var(--text); }
  .va-phone { color: var(--accent); font-weight: 600; font-size: 0.9rem; }

  .va-hero { position: relative; overflow: hidden; }
  .va-hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(135deg, rgba(245,158,11,0.08) 0%, transparent 50%),
      radial-gradient(circle at 20% 80%, rgba(245,158,11,0.03) 0%, transparent 50%);
  }
  .va-hero-bg::after {
    content: ''; position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .va-hero-content {
    position: relative; max-width: 1200px; margin: 0 auto; padding: 100px 24px 80px;
    text-align: center;
  }
  .va-hero-content h1 {
    font-size: 3rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff 60%, var(--accent)); -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .va-hero-content p {
    font-size: 1.1rem; color: var(--muted); max-width: 600px; margin: 0 auto 2rem;
  }
  .va-hero-actions { display: flex; gap: 12px; justify-content: center; }
  .va-btn {
    padding: 12px 28px; border-radius: 8px; font-weight: 600; font-size: 0.95rem;
    transition: all 0.15s;
  }
  .va-btn-primary { background: var(--accent); color: #000; }
  .va-btn-primary:hover { background: #d97706; }
  .va-btn-secondary { border: 1px solid rgba(255,255,255,0.15); color: var(--text); }
  .va-btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  .va-categories { padding: 80px 0; }
  .va-cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
  .va-cat-card {
    background: var(--surface); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;
    padding: 24px; transition: all 0.2s;
  }
  .va-cat-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .va-cat-icon {
    width: 48px; height: 48px; border-radius: 12px; background: rgba(245,158,11,0.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; font-weight: 700; color: var(--accent); margin-bottom: 16px;
  }
  .va-cat-card h3 { font-size: 1rem; margin-bottom: 8px; color: #fff; }
  .va-cat-card p { font-size: 0.8rem; color: var(--muted); }

  .va-products { padding: 0 0 80px; }
  .va-prod-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
  .va-prod-card {
    background: var(--surface); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;
    padding: 20px; transition: border-color 0.2s;
  }
  .va-prod-card:hover { border-color: rgba(245,158,11,0.3); }
  .va-prod-card-body h3 { font-size: 0.95rem; margin-bottom: 8px; color: #fff; }
  .va-price {
    display: inline-block; font-size: 1.25rem; font-weight: 700; color: var(--accent);
    margin-bottom: 8px;
  }
  .va-prod-card-body ul { list-style: none; padding: 0; }
  .va-prod-card-body li { font-size: 0.8rem; color: var(--muted); margin-bottom: 2px; }
  .va-prod-card-body li::before { content: '— '; }

  .va-footer { background: var(--surface); border-top: 1px solid rgba(255,255,255,0.06); padding: 48px 0 24px; }
  .va-footer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-bottom: 32px; }
  .va-footer h4 { font-size: 0.9rem; font-weight: 600; color: #fff; margin-bottom: 12px; }
  .va-footer p { font-size: 0.85rem; color: var(--muted); margin-bottom: 6px; }
  .va-footer a { color: var(--muted); }
  .va-footer a:hover { color: var(--accent); }
  .va-footer-bottom { text-align: center; font-size: 0.8rem; color: var(--muted); padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.06); }
</style>
