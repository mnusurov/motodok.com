---
// PROTOTYPE Variant B — «Diagnostic HUD»: тёмный графит + циан, стеклянные панели,
// анимация сканера в hero, tilt-карточки, горизонтальный рейл товаров.
const { showcase, categories, brands, news, stats, advantages, testimonials } = Astro.props;
const hero = showcase[0];
---

<div class="vb">
  <header class="vb-header">
    <a class="vb-logo" href="#"><span class="vb-dot"></span>MOTODOK</a>
    <nav>
      <a href="#">Каталог</a><a href="#">Приборы</a><a href="#">Базы данных</a><a href="#">Журнал</a>
    </nav>
    <a class="vb-btn vb-btn-sm" href="#">Консультация</a>
  </header>

  <section class="vb-hero">
    <div class="vb-hero-inner">
      <div class="vb-status vb-mono">
        <span class="vb-pulse"></span> система онлайн · 19 лет в диагностике · доставка по СНГ
      </div>
      <h1>Диагностика на уровне <span class="vb-glow">дилера</span></h1>
      <p class="vb-sub">Сканеры, осциллографы и программаторы, с которыми автосервис читает любой блок — от CAN-шины до иммобилайзера.</p>
      <div class="vb-cta-row">
        <a class="vb-btn" href="#">Открыть каталог</a>
        <a class="vb-btn vb-btn-ghost" href="#">Подобрать под марку</a>
      </div>
      <div class="vb-hero-device reveal">
        <div class="vb-scan-frame vb-tilt">
          <img src={hero.image} alt={hero.title} loading="eager" />
          <div class="vb-scanline"></div>
          <span class="vb-chip vb-chip-1 vb-mono">OBD-II · CAN</span>
          <span class="vb-chip vb-chip-2 vb-mono">{hero.title}</span>
          <span class="vb-chip vb-chip-3 vb-mono">${hero.price} · в наличии</span>
        </div>
      </div>
      <div class="vb-stats">
        {stats.map(s => (
          <div class="vb-stat">
            <span class="vb-stat-num" data-count={s.number} data-suffix={s.suffix}>0</span>
            <span class="vb-stat-label vb-mono">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="vb-section">
    <div class="vb-head reveal">
      <span class="vb-eyebrow vb-mono">// каталог</span>
      <h2>Направления оборудования</h2>
    </div>
    <div class="vb-cat-grid">
      {categories.map((c, i) => (
        <a class="vb-cat vb-tilt reveal" href={c.href} style={`transition-delay:${i * 70}ms`}>
          <span class="vb-bracket tl"></span><span class="vb-bracket br"></span>
          <span class="vb-cat-count vb-mono">{String(c.count).padStart(2, '0')} поз.</span>
          <h3>{c.title}</h3>
          <span class="vb-cat-go vb-mono">перейти &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="vb-section">
    <div class="vb-head vb-head-row reveal">
      <div>
        <span class="vb-eyebrow vb-mono">// витрина</span>
        <h2>Флагманы каталога</h2>
      </div>
      <div class="vb-rail-nav">
        <button type="button" data-rail-dir="-1" aria-label="Назад">&larr;</button>
        <button type="button" data-rail-dir="1" aria-label="Вперёд">&rarr;</button>
      </div>
    </div>
    <div class="vb-rail" id="vbRail">
      {showcase.map(p => (
        <a class="vb-card vb-tilt" href={p.href}>
          <div class="vb-card-img"><img src={p.image} alt={p.title} loading="lazy" /></div>
          <div class="vb-card-body">
            <span class="vb-card-title">{p.title}</span>
            <div class="vb-card-foot">
              <span class="vb-price vb-mono">${p.price}</span>
              <span class="vb-stock vb-mono"><span class="vb-pulse"></span> в наличии</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="vb-section">
    <div class="vb-head reveal">
      <span class="vb-eyebrow vb-mono">// протокол работы</span>
      <h2>Почему выбирают нас</h2>
    </div>
    <div class="vb-adv-grid">
      {advantages.map((a, i) => (
        <div class="vb-adv reveal" style={`transition-delay:${(i % 3) * 80}ms`}>
          <span class="vb-adv-num vb-mono">[{String(i + 1).padStart(2, '0')}]</span>
          <h3>{a.title}</h3>
          <p>{a.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="vb-section vb-brands-section reveal">
    <div class="vb-brands">
      {brands.map(b => (
        <span class="vb-brand" title={b.title}>{b.logo ? <Fragment set:html={b.logo} /> : b.title}</span>
      ))}
    </div>
  </section>

  <section class="vb-section">
    <div class="vb-head reveal">
      <span class="vb-eyebrow vb-mono">// журнал отзывов</span>
      <h2>Логи довольных клиентов</h2>
    </div>
    <div class="vb-logs">
      {testimonials.map((t, i) => (
        <div class="vb-log reveal" style={`transition-delay:${i * 80}ms`}>
          <div class="vb-log-head vb-mono">
            <span class="vb-log-ok">&#10003; verified</span>
            <span>{t.name} · {t.role}</span>
          </div>
          <p>{t.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="vb-section">
    <div class="vb-head reveal">
      <span class="vb-eyebrow vb-mono">// журнал</span>
      <h2>Статьи и новости</h2>
    </div>
    <div class="vb-news-grid">
      {news.map((n, i) => (
        <a class="vb-news reveal" href={n.href} style={`transition-delay:${i * 60}ms`}>
          <span class="vb-mono vb-news-meta">{n.type} · {n.dateStr}</span>
          <h3>{n.title}</h3>
          <span class="vb-cat-go vb-mono">читать &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="vb-final reveal">
    <div class="vb-final-inner">
      <span class="vb-eyebrow vb-mono">// связь</span>
      <h2>Запустим диагностику вашего сервиса</h2>
      <p class="vb-sub">Поможем собрать комплект под марки, с которыми вы работаете.</p>
      <div class="vb-cta-row">
        <a class="vb-btn" href="#">+996 772 553-731</a>
        <a class="vb-btn vb-btn-ghost" href="#">Написать в WhatsApp</a>
      </div>
    </div>
  </section>

  <footer class="vb-footer vb-mono">
    <span>© 2007–2026 motodok.com</span>
    <span>diag / measure / immo / odo / data</span>
  </footer>
</div>

<style>
  .vb {
    --bg: #0a0e13;
    --panel: rgba(255,255,255,.04);
    --line: rgba(148,222,233,.14);
    --text: #e8eef2;
    --dim: #8b98a5;
    --cyan: #2fe0d0;
    --cyan-soft: rgba(47,224,208,.12);
    font-family: 'Manrope', sans-serif;
    background:
      radial-gradient(1000px 500px at 70% -10%, rgba(47,224,208,.08), transparent 60%),
      radial-gradient(800px 600px at 10% 30%, rgba(60,110,255,.06), transparent 60%),
      var(--bg);
    color: var(--text); line-height: 1.6;
  }
  .vb-mono { font-family: 'JetBrains Mono', monospace; font-size: .72rem; letter-spacing: .06em; text-transform: uppercase; color: var(--dim) }

  .vb-header { display: flex; align-items: center; justify-content: space-between; gap: 2rem;
    padding: 0 clamp(1rem, 4vw, 3rem); height: 66px; position: sticky; top: 0; z-index: 50;
    background: rgba(10,14,19,.75); backdrop-filter: blur(14px); border-bottom: 1px solid var(--line) }
  .vb-logo { font-weight: 800; letter-spacing: .04em; display: inline-flex; align-items: center; gap: .5rem }
  .vb-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 12px var(--cyan) }
  .vb-header nav { display: flex; gap: 1.5rem }
  .vb-header nav a { font-size: .9rem; color: var(--dim); transition: color .2s }
  .vb-header nav a:hover { color: var(--cyan) }

  .vb-btn { display: inline-flex; align-items: center; gap: .5rem; background: var(--cyan); color: #05221f;
    font-weight: 700; padding: .85rem 1.6rem; border-radius: 10px; transition: box-shadow .2s, transform .2s }
  .vb-btn:hover { box-shadow: 0 0 28px rgba(47,224,208,.45); transform: translateY(-2px) }
  .vb-btn-sm { padding: .5rem 1rem; font-size: .85rem }
  .vb-btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--line) }
  .vb-btn-ghost:hover { border-color: var(--cyan); color: var(--cyan); box-shadow: none }

  .vb-hero { padding: clamp(3.5rem, 7vw, 6rem) clamp(1rem, 4vw, 3rem) 2rem; text-align: center;
    background-image: radial-gradient(rgba(148,222,233,.12) 1px, transparent 1px); background-size: 28px 28px }
  .vb-hero-inner { max-width: 1100px; margin: 0 auto }
  .vb-status { display: inline-flex; align-items: center; gap: .6rem; border: 1px solid var(--line);
    border-radius: 999px; padding: .45rem 1.1rem; background: var(--panel) }
  .vb-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); display: inline-block;
    animation: vb-pulse 1.6s ease infinite }
  @keyframes vb-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(47,224,208,.5) } 50% { box-shadow: 0 0 0 7px rgba(47,224,208,0) } }
  .vb-hero h1 { font-size: clamp(2.4rem, 5.5vw, 4.4rem); line-height: 1.05; letter-spacing: -.02em; font-weight: 800; margin: 1.4rem auto 1rem; max-width: 18ch }
  .vb-glow { color: var(--cyan); text-shadow: 0 0 34px rgba(47,224,208,.55) }
  .vb-sub { color: var(--dim); font-size: 1.08rem; max-width: 44rem; margin: 0 auto }
  .vb-cta-row { display: flex; gap: 1rem; justify-content: center; margin-top: 1.8rem; flex-wrap: wrap }

  .vb-hero-device { margin: 3rem auto 0; max-width: 560px }
  .vb-scan-frame { position: relative; border: 1px solid var(--line); border-radius: 18px; background: var(--panel);
    padding: 2.4rem; overflow: hidden; backdrop-filter: blur(6px) }
  .vb-scan-frame img { max-height: 300px; margin: 0 auto; object-fit: contain; filter: drop-shadow(0 24px 40px rgba(0,0,0,.6)) }
  .vb-scanline { position: absolute; left: 0; right: 0; top: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    box-shadow: 0 0 18px var(--cyan); animation: vb-scan 3.4s ease-in-out infinite }
  @keyframes vb-scan { 0%,100% { top: 8% } 50% { top: 90% } }
  .vb-chip { position: absolute; background: rgba(10,14,19,.85); border: 1px solid var(--line);
    border-radius: 8px; padding: .4rem .7rem; color: var(--cyan) }
  .vb-chip-1 { top: 14px; left: 14px } .vb-chip-2 { bottom: 14px; left: 14px } .vb-chip-3 { top: 14px; right: 14px }

  .vb-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line);
    border: 1px solid var(--line); border-radius: 14px; overflow: hidden; margin-top: 3rem }
  .vb-stat { background: rgba(10,14,19,.9); padding: 1.6rem 1rem; display: flex; flex-direction: column; gap: .3rem }
  .vb-stat-num { font-size: clamp(1.8rem, 3.4vw, 2.6rem); font-weight: 800; color: var(--cyan); font-variant-numeric: tabular-nums }

  .vb-section { padding: clamp(3rem, 6vw, 5rem) clamp(1rem, 4vw, 3rem); max-width: 1240px; margin: 0 auto }
  .vb-eyebrow { color: var(--cyan) }
  .vb-head { margin-bottom: 2.2rem }
  .vb-head h2 { font-size: clamp(1.7rem, 3.2vw, 2.5rem); letter-spacing: -.015em; font-weight: 800; margin-top: .4rem }
  .vb-head-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem }
  .vb-rail-nav { display: flex; gap: .6rem }
  .vb-rail-nav button { width: 42px; height: 42px; border-radius: 10px; border: 1px solid var(--line);
    background: var(--panel); color: var(--text); transition: all .2s }
  .vb-rail-nav button:hover { border-color: var(--cyan); color: var(--cyan) }

  .vb-cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem }
  .vb-cat { position: relative; border: 1px solid var(--line); border-radius: 14px; background: var(--panel);
    padding: 1.8rem; display: flex; flex-direction: column; gap: .7rem; transition: border-color .25s, background .25s }
  .vb-cat h3 { font-size: 1.3rem; font-weight: 700 }
  .vb-cat-go { color: var(--cyan); opacity: 0; transform: translateX(-6px); transition: all .25s }
  .vb-cat:hover { border-color: rgba(47,224,208,.5); background: var(--cyan-soft) }
  .vb-cat:hover .vb-cat-go { opacity: 1; transform: none }
  .vb-bracket { position: absolute; width: 16px; height: 16px; border: 2px solid var(--cyan); opacity: 0; transition: opacity .25s }
  .vb-bracket.tl { top: 8px; left: 8px; border-right: 0; border-bottom: 0 }
  .vb-bracket.br { bottom: 8px; right: 8px; border-left: 0; border-top: 0 }
  .vb-cat:hover .vb-bracket { opacity: 1 }

  .vb-rail { display: flex; gap: 1.2rem; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 1rem;
    scrollbar-width: thin; scrollbar-color: var(--cyan) transparent }
  .vb-card { flex: 0 0 270px; scroll-snap-align: start; border: 1px solid var(--line); border-radius: 14px;
    background: var(--panel); overflow: hidden; transition: border-color .25s; display: flex; flex-direction: column }
  .vb-card:hover { border-color: rgba(47,224,208,.5) }
  .vb-card-img { background: #fff; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; padding: 1.2rem }
  .vb-card-img img { max-height: 100%; object-fit: contain }
  .vb-card-body { padding: 1.1rem 1.2rem; display: flex; flex-direction: column; gap: .8rem; flex: 1 }
  .vb-card-title { font-weight: 600; font-size: .95rem; line-height: 1.4 }
  .vb-card-foot { margin-top: auto; display: flex; justify-content: space-between; align-items: center }
  .vb-price { color: var(--cyan); font-size: .95rem }
  .vb-stock { display: inline-flex; align-items: center; gap: .4rem; font-size: .65rem }

  .vb-adv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem }
  .vb-adv { border: 1px solid var(--line); border-radius: 14px; padding: 1.6rem; background: var(--panel) }
  .vb-adv-num { color: var(--cyan) }
  .vb-adv h3 { margin: .7rem 0 .4rem; font-size: 1.1rem } .vb-adv p { color: var(--dim); font-size: .93rem }

  .vb-brands-section { padding-top: 0 }
  .vb-brands { display: flex; flex-wrap: wrap; gap: 2.5rem 3.5rem; justify-content: center; align-items: center;
    border-block: 1px solid var(--line); padding: 2rem 0 }
  .vb-brand { color: var(--dim); font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: .1em;
    font-size: .85rem; opacity: .75; transition: opacity .2s, color .2s }
  .vb-brand:hover { opacity: 1; color: var(--cyan) }
  .vb-brand :global(svg) { height: 24px; width: auto }

  .vb-logs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem }
  .vb-log { border: 1px solid var(--line); border-left: 3px solid var(--cyan); border-radius: 10px;
    background: var(--panel); padding: 1.4rem }
  .vb-log-head { display: flex; flex-direction: column; gap: .3rem; margin-bottom: .8rem }
  .vb-log-ok { color: var(--cyan) }
  .vb-log p { font-size: .93rem; color: #c6d0d9 }

  .vb-news-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem }
  .vb-news { border: 1px solid var(--line); border-radius: 14px; padding: 1.4rem; background: var(--panel);
    display: flex; flex-direction: column; gap: .8rem; transition: border-color .25s }
  .vb-news h3 { font-size: 1rem; line-height: 1.45; font-weight: 600; flex: 1 }
  .vb-news:hover { border-color: rgba(47,224,208,.5) }
  .vb-news:hover .vb-cat-go { opacity: 1; transform: none }
  .vb-news .vb-cat-go { opacity: 0; transform: translateX(-6px) }

  .vb-final { max-width: none; padding-inline: clamp(1rem, 4vw, 3rem) }
  .vb-final-inner { max-width: 1240px; margin: 0 auto; border: 1px solid var(--line); border-radius: 20px;
    background: radial-gradient(600px 300px at 50% 0%, rgba(47,224,208,.14), transparent 70%), var(--panel);
    text-align: center; padding: clamp(3rem, 6vw, 5rem) 1.5rem }
  .vb-final h2 { font-size: clamp(1.9rem, 4vw, 3rem); letter-spacing: -.02em; margin: .6rem 0 .8rem }

  .vb-footer { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    padding: 1.8rem clamp(1rem, 4vw, 3rem); border-top: 1px solid var(--line); margin-top: 3rem }

  @media (max-width: 900px) {
    .vb-header nav { display: none }
    .vb-stats { grid-template-columns: repeat(2, 1fr) }
    .vb-cat-grid, .vb-adv-grid, .vb-logs { grid-template-columns: 1fr }
    .vb-news-grid { grid-template-columns: repeat(2, 1fr) }
    .vb-chip-2 { display: none }
  }
</style>

<script is:inline>
  // рейл товаров + tilt-эффект варианта B
  (function () {
    const rail = document.getElementById('vbRail');
    if (rail) {
      document.querySelectorAll('[data-rail-dir]').forEach(btn =>
        btn.addEventListener('click', () =>
          rail.scrollBy({ left: Number(btn.dataset.railDir) * 300, behavior: 'smooth' })));
    }
    if (matchMedia('(hover: hover) and (prefers-reduced-motion: no-preference)').matches) {
      document.querySelectorAll('.vb-tilt').forEach(el => {
        el.addEventListener('mousemove', e => {
          const r = el.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width - 0.5;
          const y = (e.clientY - r.top) / r.height - 0.5;
          el.style.transform = `perspective(700px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg)`;
        });
        el.addEventListener('mouseleave', () => { el.style.transform = ''; });
      });
    }
  })();
</script>
