---
// PROTOTYPE Variant C — «Премиум-шоурум»: тёплый кремовый фон, серифные заголовки,
// глубокий зелёный акцент, арочные формы, редакционные секции, крупный pull-quote.
const { showcase, categories, brands, news, stats, advantages, testimonials } = Astro.props;
const hero = showcase[0];
const second = showcase[1];
---

<div class="vc">
  <header class="vc-header">
    <nav class="vc-nav-left">
      <a href="#">Каталог</a><a href="#">Приборы</a><a href="#">Базы данных</a>
    </nav>
    <a class="vc-logo" href="#">Motodok</a>
    <nav class="vc-nav-right">
      <a href="#">Журнал</a><a href="#">Доставка</a><a href="#">Контакты</a>
    </nav>
  </header>

  <section class="vc-hero">
    <div class="vc-hero-text">
      <p class="vc-kicker">Профессиональная автодиагностика · с 2007 года</p>
      <h1>Инструменты, достойные вашего сервиса</h1>
      <p class="vc-lede">Дилерские сканеры, осциллографы и базы данных — отобранные, проверенные и доставленные в любую точку СНГ.</p>
      <div class="vc-cta-row">
        <a class="vc-btn" href="#">Перейти в каталог</a>
        <a class="vc-link" href="#">Получить консультацию &rarr;</a>
      </div>
      <div class="vc-hero-stats">
        {stats.slice(0, 3).map(s => (
          <div class="vc-hero-stat">
            <span class="vc-hero-stat-num" data-count={s.number} data-suffix={s.suffix}>0</span>
            <span class="vc-hero-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="vc-hero-media reveal">
      <div class="vc-arch vc-parallax"><img src={hero.image} alt={hero.title} loading="eager" /></div>
      <div class="vc-arch vc-arch-sm vc-parallax" data-speed="1.6"><img src={second.image} alt={second.title} loading="lazy" /></div>
    </div>
  </section>

  <section class="vc-band">
    {brands.slice(0, 10).map(b => (
      <span class="vc-band-item">{b.logo ? <Fragment set:html={b.logo} /> : b.title}</span>
    ))}
  </section>

  <section class="vc-section">
    <div class="vc-head reveal">
      <p class="vc-kicker">Каталог</p>
      <h2>Пять направлений</h2>
    </div>
    <div class="vc-cat-grid">
      {categories.map((c, i) => (
        <a class={`vc-cat reveal ${i === 0 ? 'vc-cat-wide' : ''}`} href={c.href} style={`transition-delay:${i * 70}ms`}>
          <span class="vc-cat-index">{['I', 'II', 'III', 'IV', 'V', 'VI'][i]}</span>
          <h3>{c.title}</h3>
          <p class="vc-cat-meta">{c.count} позиций в наличии</p>
          <span class="vc-cat-cta">Смотреть коллекцию &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="vc-section vc-showroom">
    <div class="vc-head vc-head-row reveal">
      <div>
        <p class="vc-kicker">Витрина</p>
        <h2>Избранное оборудование</h2>
      </div>
      <div class="vc-rail-nav">
        <button type="button" data-rail-dir="-1" aria-label="Назад">&larr;</button>
        <button type="button" data-rail-dir="1" aria-label="Вперёд">&rarr;</button>
      </div>
    </div>
    <div class="vc-rail" id="vcRail">
      {showcase.map(p => (
        <a class="vc-product" href={p.href}>
          <div class="vc-product-img"><img src={p.image} alt={p.title} loading="lazy" /></div>
          <div class="vc-product-body">
            <span class="vc-product-title">{p.title}</span>
            <span class="vc-product-price">${p.price} <small>USD</small></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="vc-section vc-values">
    <div class="vc-head reveal">
      <p class="vc-kicker">Наш подход</p>
      <h2>Как мы работаем</h2>
    </div>
    <div class="vc-values-list">
      {advantages.slice(0, 4).map((a, i) => (
        <div class="vc-value reveal" style={`transition-delay:${i * 70}ms`}>
          <span class="vc-value-num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{a.title}</h3>
            <p>{a.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="vc-quote reveal">
    <div class="vc-quote-inner">
      <div class="vc-stars" aria-hidden="true">★★★★★</div>
      {testimonials.map((t, i) => (
        <blockquote data-idx={i} hidden={i !== 0}>
          <p>«{t.text}»</p>
          <footer>{t.name}, <span>{t.role}</span></footer>
        </blockquote>
      ))}
      <div class="vc-quote-dots">
        {testimonials.map((_, i) => (
          <button type="button" class={`vc-dot ${i === 0 ? 'is-active' : ''}`} data-q-idx={i} aria-label={`Отзыв ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </section>

  <section class="vc-section">
    <div class="vc-head reveal">
      <p class="vc-kicker">Журнал</p>
      <h2>Читать о диагностике</h2>
    </div>
    <div class="vc-journal">
      {news.map((n, i) => (
        <a class="vc-journal-row reveal" href={n.href} style={`transition-delay:${i * 60}ms`}>
          <span class="vc-journal-date">{n.dateStr}</span>
          <span class="vc-journal-title">{n.title}</span>
          <span class="vc-journal-type">{n.type}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="vc-final reveal">
    <h2>Расскажите, какие марки вы обслуживаете, — соберём комплект под них</h2>
    <div class="vc-cta-row vc-cta-center">
      <a class="vc-btn vc-btn-light" href="#">+996 772 553-731</a>
      <a class="vc-link vc-link-light" href="#">Написать нам &rarr;</a>
    </div>
  </section>

  <footer class="vc-footer">
    <a class="vc-logo" href="#">Motodok</a>
    <p>Оборудование для автодиагностики · Бишкек · доставка по СНГ</p>
    <p class="vc-footer-copy">© 2007–2026</p>
  </footer>
</div>

<style>
  .vc {
    --cream: #f6f1e7;
    --cream2: #efe8d9;
    --ink: #24231e;
    --muted: #6f6a5c;
    --green: #1f4d3f;
    --green-deep: #143529;
    --gold: #b98a2f;
    --line: #ddd5c3;
    font-family: 'Manrope', sans-serif;
    background: var(--cream); color: var(--ink); line-height: 1.65;
  }
  .vc h1, .vc h2, .vc .vc-logo, .vc blockquote p { font-family: 'Playfair Display', Georgia, serif }

  .vc-header { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding: 0 clamp(1rem, 4vw, 3rem); height: 74px; border-bottom: 1px solid var(--line);
    position: sticky; top: 0; background: rgba(246,241,231,.9); backdrop-filter: blur(10px); z-index: 50 }
  .vc-logo { font-size: 1.5rem; font-weight: 600; font-style: italic; text-align: center }
  .vc-nav-left, .vc-nav-right { display: flex; gap: 1.6rem }
  .vc-nav-right { justify-content: flex-end }
  .vc-header nav a { font-size: .88rem; letter-spacing: .02em; color: var(--muted); transition: color .2s }
  .vc-header nav a:hover { color: var(--green) }

  .vc-kicker { font-size: .78rem; text-transform: uppercase; letter-spacing: .18em; color: var(--gold); font-weight: 600 }

  .vc-hero { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(2rem, 5vw, 5rem); align-items: center;
    max-width: 1240px; margin: 0 auto; padding: clamp(3rem, 7vw, 6rem) clamp(1rem, 4vw, 3rem) }
  .vc-hero h1 { font-size: clamp(2.6rem, 5.2vw, 4.4rem); line-height: 1.08; font-weight: 600; letter-spacing: -.01em; margin: 1.1rem 0 }
  .vc-lede { color: var(--muted); font-size: 1.12rem; max-width: 32rem }
  .vc-cta-row { display: flex; align-items: center; gap: 1.6rem; margin-top: 2rem; flex-wrap: wrap }
  .vc-btn { background: var(--green); color: var(--cream); padding: 1rem 2rem; border-radius: 999px;
    font-weight: 600; transition: background .25s, transform .25s, box-shadow .25s }
  .vc-btn:hover { background: var(--green-deep); transform: translateY(-2px); box-shadow: 0 16px 34px -16px rgba(31,77,63,.55) }
  .vc-btn-light { background: var(--cream); color: var(--green-deep) }
  .vc-btn-light:hover { background: #fff }
  .vc-link { color: var(--green); font-weight: 600; border-bottom: 1px solid transparent; transition: border-color .2s }
  .vc-link:hover { border-color: var(--green) }
  .vc-link-light { color: var(--cream) } .vc-link-light:hover { border-color: var(--cream) }

  .vc-hero-stats { display: flex; gap: 2.6rem; margin-top: 3rem; border-top: 1px solid var(--line); padding-top: 1.6rem }
  .vc-hero-stat { display: flex; flex-direction: column }
  .vc-hero-stat-num { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--green); font-variant-numeric: tabular-nums }
  .vc-hero-stat-label { font-size: .82rem; color: var(--muted) }

  .vc-hero-media { position: relative; display: flex; justify-content: center }
  .vc-arch { background: #fff; border-radius: 200px 200px 18px 18px; padding: 2.6rem 2rem 2rem;
    box-shadow: 0 30px 60px -30px rgba(36,35,30,.35); width: min(380px, 80%) }
  .vc-arch img { max-height: 320px; object-fit: contain; margin: 0 auto; mix-blend-mode: multiply }
  .vc-arch-sm { position: absolute; right: -10px; bottom: -34px; width: 170px; padding: 1.4rem 1rem 1rem;
    border: 1px solid var(--line) }
  .vc-arch-sm img { max-height: 120px }

  .vc-band { display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem 3.5rem; align-items: center;
    border-block: 1px solid var(--line); background: var(--cream2); padding: 1.6rem clamp(1rem, 4vw, 3rem) }
  .vc-band-item { color: var(--muted); font-size: .85rem; text-transform: uppercase; letter-spacing: .14em; opacity: .8 }
  .vc-band-item :global(svg) { height: 22px; width: auto }

  .vc-section { max-width: 1240px; margin: 0 auto; padding: clamp(3rem, 6vw, 5.5rem) clamp(1rem, 4vw, 3rem) }
  .vc-head { margin-bottom: 2.4rem }
  .vc-head h2 { font-size: clamp(1.9rem, 3.6vw, 3rem); font-weight: 600; margin-top: .5rem }
  .vc-head-row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem }

  .vc-cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem }
  .vc-cat { background: #fff; border-radius: 18px; padding: 2rem; display: flex; flex-direction: column; gap: .5rem;
    border: 1px solid var(--line); transition: transform .3s, box-shadow .3s }
  .vc-cat:hover { transform: translateY(-6px); box-shadow: 0 26px 50px -28px rgba(36,35,30,.4) }
  .vc-cat-wide { grid-column: span 2; background: var(--green); color: var(--cream); border: none }
  .vc-cat-wide .vc-cat-meta { color: rgba(246,241,231,.65) }
  .vc-cat-wide .vc-cat-cta { color: var(--cream) }
  .vc-cat-index { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.4rem; color: var(--gold) }
  .vc-cat h3 { font-size: 1.5rem; font-family: 'Playfair Display', serif; font-weight: 600 }
  .vc-cat-meta { color: var(--muted); font-size: .9rem; flex: 1 }
  .vc-cat-cta { color: var(--green); font-weight: 600; font-size: .92rem; margin-top: 1.2rem; opacity: 0; transform: translateX(-8px); transition: all .3s }
  .vc-cat:hover .vc-cat-cta { opacity: 1; transform: none }

  .vc-showroom { background: var(--cream2); max-width: none }
  .vc-showroom > * { max-width: 1240px; margin-inline: auto }
  .vc-rail-nav { display: flex; gap: .6rem }
  .vc-rail-nav button { width: 46px; height: 46px; border-radius: 50%; border: 1px solid var(--ink);
    background: none; color: var(--ink); font-size: 1.05rem; transition: all .2s }
  .vc-rail-nav button:hover { background: var(--ink); color: var(--cream) }
  .vc-rail { display: flex; gap: 1.4rem; overflow-x: auto; scroll-snap-type: x mandatory; padding: .4rem .2rem 1.2rem;
    scrollbar-width: none }
  .vc-rail::-webkit-scrollbar { display: none }
  .vc-product { flex: 0 0 300px; scroll-snap-align: start; background: #fff; border-radius: 18px; overflow: hidden;
    box-shadow: 0 14px 34px -20px rgba(36,35,30,.28); transition: transform .3s, box-shadow .3s }
  .vc-product:hover { transform: translateY(-6px); box-shadow: 0 30px 56px -26px rgba(36,35,30,.42) }
  .vc-product-img { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; padding: 2rem }
  .vc-product-img img { max-height: 100%; object-fit: contain; mix-blend-mode: multiply; transition: transform .4s }
  .vc-product:hover .vc-product-img img { transform: scale(1.05) }
  .vc-product-body { padding: 1.2rem 1.4rem 1.5rem; border-top: 1px solid var(--line);
    display: flex; flex-direction: column; gap: .5rem }
  .vc-product-title { font-weight: 600; line-height: 1.4 }
  .vc-product-price { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--green) }
  .vc-product-price small { font-family: 'Manrope', sans-serif; font-size: .7rem; color: var(--muted) }

  .vc-values-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.4rem 4rem }
  .vc-value { display: flex; gap: 1.6rem; border-top: 1px solid var(--line); padding-top: 1.6rem }
  .vc-value-num { font-family: 'Playfair Display', serif; font-style: italic; font-size: 2.2rem; color: var(--gold); line-height: 1 }
  .vc-value h3 { font-size: 1.15rem; margin-bottom: .4rem }
  .vc-value p { color: var(--muted); font-size: .95rem }

  .vc-quote { background: var(--green); color: var(--cream); text-align: center;
    padding: clamp(4rem, 8vw, 6.5rem) 1.5rem }
  .vc-quote-inner { max-width: 860px; margin: 0 auto }
  .vc-stars { color: var(--gold); letter-spacing: .35em; margin-bottom: 2rem; font-size: 1.1rem }
  .vc-quote blockquote p { font-size: clamp(1.4rem, 2.8vw, 2rem); line-height: 1.4; font-weight: 500; font-style: italic }
  .vc-quote footer { margin-top: 1.6rem; font-size: .95rem }
  .vc-quote footer span { color: rgba(246,241,231,.6) }
  .vc-quote-dots { margin-top: 2.2rem; display: flex; gap: .7rem; justify-content: center }
  .vc-dot { width: 9px; height: 9px; border-radius: 50%; border: 1px solid var(--cream); background: none; padding: 0; transition: background .2s }
  .vc-dot.is-active, .vc-dot:hover { background: var(--cream) }

  .vc-journal { border-top: 1px solid var(--line) }
  .vc-journal-row { display: grid; grid-template-columns: 12rem 1fr 6rem; gap: 1.6rem; align-items: baseline;
    padding: 1.5rem .4rem; border-bottom: 1px solid var(--line); transition: background .2s }
  .vc-journal-date { color: var(--muted); font-size: .85rem }
  .vc-journal-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; transition: color .2s }
  .vc-journal-type { text-align: right; font-size: .78rem; text-transform: uppercase; letter-spacing: .12em; color: var(--gold) }
  .vc-journal-row:hover { background: rgba(255,255,255,.55) }
  .vc-journal-row:hover .vc-journal-title { color: var(--green) }

  .vc-final { background: var(--green-deep); color: var(--cream); text-align: center;
    padding: clamp(4rem, 8vw, 7rem) 1.5rem }
  .vc-final h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3.8vw, 2.9rem);
    font-weight: 600; max-width: 26ch; margin: 0 auto }
  .vc-cta-center { justify-content: center; margin-top: 2.4rem }

  .vc-footer { text-align: center; padding: 3rem 1.5rem; border-top: 1px solid var(--line);
    display: flex; flex-direction: column; gap: .6rem }
  .vc-footer p { color: var(--muted); font-size: .9rem }
  .vc-footer-copy { font-size: .8rem }

  @media (max-width: 900px) {
    .vc-header { grid-template-columns: auto 1fr; }
    .vc-nav-left { display: none }
    .vc-hero { grid-template-columns: 1fr }
    .vc-cat-grid { grid-template-columns: 1fr } .vc-cat-wide { grid-column: auto }
    .vc-values-list { grid-template-columns: 1fr }
    .vc-journal-row { grid-template-columns: 1fr; gap: .3rem }
    .vc-journal-type { text-align: left }
    .vc-arch-sm { display: none }
  }
</style>

<script is:inline>
  // рейл, точки отзывов и лёгкий параллакс варианта C
  (function () {
    const rail = document.getElementById('vcRail');
    if (rail) {
      document.querySelectorAll('.vc-rail-nav [data-rail-dir]').forEach(btn =>
        btn.addEventListener('click', () =>
          rail.scrollBy({ left: Number(btn.dataset.railDir) * 330, behavior: 'smooth' })));
    }
    const quotes = document.querySelectorAll('.vc-quote blockquote');
    const dots = document.querySelectorAll('.vc-dot');
    dots.forEach(dot => dot.addEventListener('click', () => {
      const idx = Number(dot.dataset.qIdx);
      quotes.forEach((q, i) => { q.hidden = i !== idx; });
      dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
    }));
    if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      const items = document.querySelectorAll('.vc-parallax');
      addEventListener('scroll', () => {
        const y = scrollY;
        items.forEach(el => {
          const speed = Number(el.dataset.speed || 1);
          el.style.translate = `0 ${Math.min(y, 600) * 0.04 * speed}px`;
        });
      }, { passive: true });
    }
  })();
</script>
