---
export interface Props {
  article: {
    title: string;
    slug: string;
    description?: string;
    image?: string;
    publishedDate?: string;
  };
}

const { article } = Astro.props;
---

<article class="article-card">
  <a href={`/Articles/${article.slug}/`} class="article-card-link">
    {article.image && <img src={article.image} alt={article.title} loading="lazy" class="article-card-img" />}
    <div class="article-card-body">
      {article.publishedDate && <time class="article-card-date">{article.publishedDate}</time>}
      <h3 class="article-card-title">{article.title}</h3>
      {article.description && <p class="article-card-desc">{article.description}</p>}
    </div>
  </a>
</article>

<style>
  .article-card {
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .article-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .article-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .article-card-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .article-card-body {
    padding: 0.75rem;
  }
  .article-card-date {
    font-size: 0.8rem;
    color: #999;
  }
  .article-card-title {
    margin: 0.25rem 0 0.5rem;
    font-size: 1rem;
  }
  .article-card-desc {
    font-size: 0.85rem;
    color: #666;
    margin: 0;
  }
</style>
