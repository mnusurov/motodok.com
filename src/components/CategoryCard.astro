---
export interface Props {
  category: {
    title: string;
    slug: string;
    description?: string;
    image?: string;
    metaTitle?: string;
    metaDescription?: string;
  };
}

const { category } = Astro.props;
---

<article class="category-card">
  <a href={`/${category.slug}/`} class="category-card-link">
    {category.image && <img src={category.image} alt={category.title} loading="lazy" class="category-card-img" />}
    <div class="category-card-body">
      <h3 class="category-card-title">{category.title}</h3>
      {(category.description || category.metaDescription) && (
        <p class="category-card-desc">{category.description || category.metaDescription}</p>
      )}
    </div>
  </a>
</article>

<style>
  .category-card {
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .category-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .category-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .category-card-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
  }
  .category-card-body {
    padding: 0.75rem;
  }
  .category-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }
  .category-card-desc {
    font-size: 0.85rem;
    color: #666;
    margin: 0;
  }
</style>
