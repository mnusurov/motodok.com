---
export interface Props {
  product: {
    title: string;
    slug: string;
    category: string;
    price?: string;
    images?: string[];
    features?: string[];
    metaDescription?: string;
    availability?: 'in_stock' | 'on_order' | 'discontinued';
  };
}

const { product } = Astro.props;
const availability = product.availability || 'in_stock';
const discontinued = availability === 'discontinued';
---

<a href={`/${product.category}/${product.slug}/`} class:list={["product-card", { "is-discontinued": discontinued }]}>
  {product.images && product.images[0] && (
    <div class="product-card-img">
      <img src={product.images[0]} alt={product.title} loading="lazy" />
    </div>
  )}
  <div class="product-card-body">
    <h3>{product.title}</h3>
    {availability === 'on_order' && <span class="order-badge">Под заказ</span>}
    {discontinued && <span class="order-badge order-badge-discontinued">Товар снят с продажи</span>}
    {product.metaDescription && <p>{product.metaDescription}</p>}
  </div>
  {!discontinued && product.price && <div class="price">{product.price} $</div>}
</a>
