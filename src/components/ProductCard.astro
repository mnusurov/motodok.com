---
export interface Props {
  product: {
    title: string;
    slug: string;
    category: string;
    price?: string;
    images?: string[];
    features?: string[];
    metaDescription?: string;
  };
}

const { product } = Astro.props;
---

<article class="product-card">
  <a href={`/${product.category}/${product.slug}/`}>
    <h3>{product.title}</h3>
    {product.metaDescription && <p>{product.metaDescription}</p>}
    {product.price && <div class="price">{product.price} $</div>}
  </a>
</article>
