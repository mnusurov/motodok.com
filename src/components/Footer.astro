---
import { socialPlatforms, socialIconPaths } from '../data/social';

const categoryLinks = [
  { href: '/diagnosis/', label: 'Диагностика' },
  { href: '/odometers/', label: 'Одометры' },
  { href: '/immobilizer/', label: 'Иммобилайзеры' },
  { href: '/measure/', label: 'Осциллографы' },
  { href: '/databases/', label: 'Базы данных' },
  { href: '/services/', label: 'Услуги' },
];

const infoLinks = [
  { href: '/how-to-buy/', label: 'Как купить' },
  { href: '/prices/', label: 'Цены' },
  { href: '/documentation/', label: 'Документация' },
  { href: '/contacts/', label: 'Контакты' },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>Motodok</h4>
        <p>Оборудование для диагностики и ремонта автомобилей. Дилерские сканеры, адаптеры, осциллографы и базы данных с 2007 года.</p>
        <div class="footer-social">
          {socialPlatforms.map(p => (
            <a href={p.url} target="_blank" rel="noopener noreferrer" aria-label={p.name}>
              <svg viewBox="0 0 24 24" fill="currentColor" set:html={`<path d="${socialIconPaths[p.icon]}" />`} />
            </a>
          ))}
        </div>
      </div>
      <div class="footer-col">
        <h4>Категории</h4>
        {categoryLinks.map(link => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4>Информация</h4>
        {infoLinks.map(link => (
          <a href={link.href}>{link.label}</a>
        ))}
        <a href="/articles/">Статьи</a>
        <a href="/blog/">Блог</a>
      </div>
      <div class="footer-col">
        <h4>Контакты</h4>
        <p><a href="tel:+996312517107">+996 (312) 517-107</a></p>
        <p><a href="tel:+996551553731">+996 (551) 553-731</a></p>
        <p><a href="tel:+996772553731">+996 (772) 553-731</a></p>
        <p style="margin-top:.5rem"><a href="mailto:info@motodok.com">info@motodok.com</a></p>
        <p style="margin-top:.5rem">г. Бишкек, Кыргызстан</p>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2007-2026 <a href="/">Motodok</a></span>
      <span>Оборудование для автодиагностики</span>
    </div>
  </div>
</footer>