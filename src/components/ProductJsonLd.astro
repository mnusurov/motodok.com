---
export interface Props {
  product: {
    title: string;
    description?: string;
    price?: number;
    currency?: string;
    availability?: 'in_stock' | 'on_order' | 'discontinued';
    images?: string[];
    brand?: string;
    article?: string;
  };
}

const { product } = Astro.props;
const siteUrl = 'https://motodok.com';
const id = `${siteUrl}${Astro.url.pathname}`;

const ld: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': id,
  name: product.title,
  ...(product.description && { description: product.description }),
  ...(product.images?.length && { image: product.images.map(i => `${siteUrl}${i}`) }),
};

const availability = product.availability || 'in_stock';

if (product.price && availability !== 'discontinued') {
  ld.offers = {
    '@type': 'Offer',
    price: product.price,
    priceCurrency: product.currency || 'USD',
    availability: availability === 'in_stock'
      ? 'https://schema.org/InStock'
      : 'https://schema.org/BackOrder',
  };
}

if (product.brands?.length) {
  ld.brand = product.brands.length === 1
    ? { '@type': 'Brand', name: product.brands[0] }
    : product.brands.map((b: string) => ({ '@type': 'Brand', name: b }));
}

if (product.article) {
  ld.sku = product.article;
}
---

<script type="application/ld+json" set:html={JSON.stringify(ld, null, 2)} />
