---
import { socialPlatforms } from '../data/social';
import type { SocialPlatform } from '../data/social';

const categoryLinks = [
  { href: '/Diagnosis/', label: 'Диагностика' },
  { href: '/Odometers/', label: 'Одометры' },
  { href: '/Immobilizer/', label: 'Иммобилайзеры' },
  { href: '/Measure/', label: 'Осциллографы' },
  { href: '/Databases/', label: 'Базы данных' },
  { href: '/Services/', label: 'Услуги' },
];

const visibleSocial = socialPlatforms.slice(0, 4);
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <img src="/images/logo-mark.svg" alt="" width="28" height="28" class="logo-mark" />
      Motodok
    </a>
    <div class="header-actions">
      <nav class="nav">
        <div class="dropdown">
          <span class="dropbtn">Каталог</span>
          <div class="dropdown-content">
            {categoryLinks.map(link => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </div>
        <a href="/News/">Новости</a>
        <a href="/Articles/">Статьи</a>
        <a href="/documentation/">Файлы</a>
        <a href="/prices/">Цены</a>
        <a href="/how-to-buy/">Как купить</a>
        <a href="/contacts/">Контакты</a>
        <a href="/search/" class="search-btn" aria-label="Поиск">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      </nav>
      <button class="theme-toggle" id="themeToggle" aria-label="Переключить тему" title="Светлая/тёмная тема">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</header>
