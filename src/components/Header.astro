---
const categoryLinks = [
  { href: '/Diagnosis/', label: 'Диагностика' },
  { href: '/Odometers/', label: 'Одометры' },
  { href: '/Immobilizer/', label: 'Иммобилайзеры' },
  { href: '/Measure/', label: 'Осциллографы' },
  { href: '/Databases/', label: 'Базы данных' },
  { href: '/Services/', label: 'Услуги' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">Motodok</a>
    <nav class="nav">
      <div class="dropdown">
        <a href="/Diagnosis/" class="dropbtn">Каталог</a>
        <div class="dropdown-content">
          {categoryLinks.map(link => (
            <a href={link.href}>{link.label}</a>
          ))}
        </div>
      </div>
      <a href="/News/">Новости</a>
      <a href="/Articles/">Статьи</a>
      <a href="/documentation/">Файлы</a>
      <a href="/prices/">Цены</a>
      <a href="/how-to-buy/">Как купить</a>
      <a href="/contacts/">Контакты</a>
      <a href="/search/" class="search-btn" aria-label="Поиск">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </a>
    </nav>
  </div>
</header>
