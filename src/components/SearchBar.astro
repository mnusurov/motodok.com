---

<form class="search-bar" action="/search/" method="get" role="search">
  <input type="search" name="q" class="search-input" placeholder="Поиск..." aria-label="Поиск по сайту" />
  <button type="submit" class="search-btn">Найти</button>
</form>

<style>
  .search-bar {
    display: flex;
    gap: 0.5rem;
    max-width: 400px;
  }
  .search-input {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.9rem;
  }
  .search-btn {
    padding: 0.5rem 1rem;
    background: #1a1a2e;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .search-btn:hover {
    background: #16213e;
  }
</style>
